# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Diagnostic reports (https://nodejs.org/api/report.html)
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Coverage
coverage
*.lcov
.nyc_output

# Compiled binary addons
build/Release

# Dependency directories
node_modules/

# TypeScript cache
*.tsbuildinfo

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# dotenv environment variables file
.env
.env.test

# Next.js build output
.next

# Serverless directories
.serverless/

# Claude Code project settings and memory
.claude/

# Git worktrees
.worktrees/

# Local tool cache (sandbox-safe cache root — see CLAUDE.md)
.cache/*
!.cache/.gitkeep

# Azure Functions build output and local settings
functions/local.settings.json
functions/dist/

# Vite build output (frontend)
frontend/dist/
