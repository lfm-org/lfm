{
  "name": "lfm-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "vite",
    "dev:e2e": "FRONTEND_PORT=${FRONTEND_PORT:-4173} vite --host 127.0.0.1",
    "build": "tsc --noEmit && vite build",
    "bundle:check": "node ./scripts/check-bundle.mjs",
    "lint": "eslint --max-warnings=0 src eslint.config.mjs vite.config.ts vitest.config.ts vitest.integration.config.ts playwright.config.ts",
    "preview": "vite preview",
    "test": "pnpm test:unit && pnpm test:integration",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "e2e": "playwright test",
    "e2e:list": "playwright test --list",
    "verify:fast": "pnpm lint && pnpm test && pnpm build && pnpm bundle:check"
  },
  "dependencies": {
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@mui/icons-material": "7.3.9",
    "@mui/material": "7.3.9",
    "@mui/x-date-pickers": "8.5.3",
    "@tanstack/react-table": "8.21.3",
    "axios": "1.13.6",
    "dompurify": "3.3.3",
    "i18next": "^26.0.2",
    "luxon": "3.6.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-i18next": "^17.0.1",
    "react-obfuscate-email": "^2.0.5",
    "react-router": "7.13.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.11.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "1.58.2",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/luxon": "3.4.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "eslint": "^10.1.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-no-unsanitized": "^4.1.5",
    "eslint-plugin-react-hooks": "7.1.0-canary-ed69815c-20260323",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^15.15.0",
    "jsdom": "^29.0.1",
    "knip": "^6.1.1",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.26.1",
    "vite": "8.0.1",
    "vitest": "4.1.2"
  }
}
