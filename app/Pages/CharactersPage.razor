@page "/characters"
@using Lfm.App.Auth
@using Lfm.App.Services
@using Lfm.Contracts.Characters
@attribute [Authorize]
@implements IAsyncDisposable
@inject IBattleNetClient BattleNetClient
@inject IMeClient MeClient
@inject IAuthStateRefresher AuthStateRefresher
@inject NavigationManager Nav
@inject IStringLocalizer Loc
@inject IJSRuntime JS

<PageTitle>@Loc["characters.title"] — @Loc["nav.logo"]</PageTitle>

<FluentStack Orientation="Orientation.Vertical" VerticalGap="16">
    <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="12" Wrap="true" Style="align-items:center">
        <FluentLabel Typo="Typography.H1" Style="flex:1">@Loc["characters.title"]</FluentLabel>
        <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8" Wrap="true" Style="align-items:center">
            <FluentSelect Id="characters-sort"
                          Label="@Loc["characters.sort"]"
                          TOption="string"
                          Value="@SortValue"
                          ValueChanged="@HandleSortChanged"
                          Disabled="@loading"
                          Style="max-inline-size:180px">
                <FluentOption TOption="string" Value="@DefaultSortValue">@Loc["characters.sort.default"]</FluentOption>
                <FluentOption TOption="string" Value="@NameSortValue">@Loc["characters.sort.name"]</FluentOption>
            </FluentSelect>
            <FluentButton Appearance="Appearance.Outline" OnClick="@RefreshCharacters" Disabled="@loading">
                @Loc["characters.refresh"]
            </FluentButton>
        </FluentStack>
    </FluentStack>

    @switch (state)
    {
        case LoadingState<IReadOnlyList<CharacterDto>>.Idle:
        case LoadingState<IReadOnlyList<CharacterDto>>.Loading:
            <FluentProgressRing />
            break;

        case LoadingState<IReadOnlyList<CharacterDto>>.Failure f:
            <FluentMessageBar Intent="MessageIntent.Error">@f.Message</FluentMessageBar>
            break;

        case LoadingState<IReadOnlyList<CharacterDto>>.Success s when s.Value.Count == 0:
            <FluentMessageBar Intent="MessageIntent.Info">
                @Loc["characters.empty"]
            </FluentMessageBar>
            break;

        case LoadingState<IReadOnlyList<CharacterDto>>.Success s:
            var visibleCharacters = VisibleCharacters;
            @if (!string.IsNullOrEmpty(selectError))
            {
                <FluentMessageBar Intent="MessageIntent.Error">@selectError</FluentMessageBar>
            }
            <div style="display:grid;gap:12px;width:100%;grid-template-columns:repeat(auto-fill,minmax(min(260px,100%),1fr))">
                @foreach (var c in visibleCharacters)
                {
                    var portraitSrc = c.PortraitUrl ?? (portraits.TryGetValue(CharKey(c), out var p) ? p : null);
                    var isSelected = CharKey(c) == selectedCharacterId;
                    var wrapperStyle = isSelected
                        ? "position:relative;cursor:default;outline:2px solid var(--accent-fill-rest);outline-offset:-1px;border-radius:4px"
                        : "position:relative;cursor:pointer";
                    <button type="button"
                            class="character-card"
                            @key="@CharKey(c)"
                            data-char-id="@CharKey(c)"
                            aria-pressed="@(isSelected ? "true" : "false")"
                            style="@wrapperStyle"
                            @onclick="@(() => HandleSelectCharacter(c))">
                        @if (isSelected)
                        {
                            <span style="display:inline-block;position:absolute;top:8px;right:8px;background:var(--accent-fill-rest);color:var(--foreground-on-accent-rest);font-size:0.7em;padding:2px 8px;border-radius:10px;z-index:1;pointer-events:none">@Loc["characters.active"]</span>
                        }
                        <FluentCard Style="padding:12px">
                            <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="12" Style="align-items:center">
                                @if (!string.IsNullOrEmpty(portraitSrc))
                                {
                                    <img src="@portraitSrc"
                                         alt="@c.Name"
                                         class="character-portrait"
                                         width="48"
                                         height="48"
                                         loading="lazy"
                                         decoding="async" />
                                }
                                else
                                {
                                    <div class="character-portrait character-portrait--placeholder">
                                        @c.Name.Substring(0, 1).ToUpperInvariant()
                                    </div>
                                }
                                <FluentStack Orientation="Orientation.Vertical" VerticalGap="2" Style="min-width:0;flex:1">
                                    <FluentLabel Style="font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">@c.Name</FluentLabel>
                                    <FluentLabel Style="font-size:0.85em;color:var(--neutral-foreground-hint-rest)">@c.RealmName</FluentLabel>
                                    <FluentLabel Style="font-size:0.8em">
                                        @(c.ClassName ?? Loc["characters.unknown"]) · @Loc["characters.level"] @c.Level
                                        @if (!string.IsNullOrEmpty(c.SpecName))
                                        {
                                            <span> · @c.SpecName</span>
                                        }
                                    </FluentLabel>
                                </FluentStack>
                            </FluentStack>
                        </FluentCard>
                    </button>
                }
            </div>
            @if (TotalPages > 1)
            {
                <nav aria-label="@Loc["characters.pagination"]" style="display:flex;align-items:center;justify-content:center;gap:8px;flex-wrap:wrap">
                    <FluentButton Appearance="Appearance.Outline"
                                  Disabled="@(CurrentPage <= 1)"
                                  OnClick="@(() => HandlePageChange(CurrentPage - 1))"
                                  aria-label="@Loc["common.previous"]">
                        @Loc["common.previous"]
                    </FluentButton>
                    <FluentLabel aria-live="polite">
                        @Loc["characters.pagination.status", CurrentPage, TotalPages]
                    </FluentLabel>
                    @for (var pageNumber = 1; pageNumber <= TotalPages; pageNumber++)
                    {
                        var page = pageNumber;
                        <FluentButton Appearance="@(page == CurrentPage ? Appearance.Accent : Appearance.Outline)"
                                      OnClick="@(() => HandlePageChange(page))"
                                      aria-current="@(page == CurrentPage ? "page" : null)"
                                      aria-label="@Loc["characters.pagination.page", page]">
                            @(page)
                        </FluentButton>
                    }
                    <FluentButton Appearance="Appearance.Outline"
                                  Disabled="@(CurrentPage >= TotalPages)"
                                  OnClick="@(() => HandlePageChange(CurrentPage + 1))"
                                  aria-label="@Loc["common.next"]">
                        @Loc["common.next"]
                    </FluentButton>
                </nav>
            }
            break;
    }

    <!-- Forget Me section -->
    <div style="border-block-start:1px solid var(--neutral-stroke-rest);padding-block-start:24px;margin-block-start:8px">
        <FluentStack Orientation="Orientation.Vertical" VerticalGap="12" Style="max-width:420px">
            <FluentLabel Typo="Typography.H4">@Loc["characters.deleteAccount.title"]</FluentLabel>
            <FluentLabel>@Loc["characters.deleteAccount.body"]</FluentLabel>
            <FluentLabel>@Loc["characters.deleteAccount.confirm"]</FluentLabel>
            <FluentTextField
                @bind-Value="deleteConfirmation"
                Placeholder="@Loc["characters.deleteAccount.placeholder"]"
                Disabled="@deleting"
                Style="max-inline-size:320px"
                @attributes="DeleteConfirmAttrs" />
            @if (!string.IsNullOrEmpty(deleteError))
            {
                <FluentMessageBar Intent="MessageIntent.Error">@deleteError</FluentMessageBar>
            }
            <FluentButton
                Appearance="Appearance.Outline"
                Disabled="@(!deleteConfirmationValid || deleting)"
                OnClick="@HandleDeleteAccount">
                @if (deleting)
                {
                    <FluentProgressRing Style="width:16px;height:16px" />
                }
                @Loc["characters.deleteAccount.button"]
            </FluentButton>
        </FluentStack>
    </div>
</FluentStack>

@code {
    private enum EnrichState { Pending, Enriching, Enriched, Failed }
    private readonly Dictionary<string, EnrichState> cardState = new();
    private readonly Dictionary<string, TaskCompletionSource> inflightEnrich = new();
    private const string NameSortValue = "name";
    private const string DefaultSortValue = "level";
    private const int DesktopPageSize = 9;
    private const int MobilePageSize = 3;
    private const int EagerEnrichCount = 1;

    private IJSObjectReference? viewportModule;
    private DotNetObjectReference<CharactersPage>? selfRef;

    private readonly Queue<string> enrichQueue = new();
    private Task? enrichWorkerTask;
    private CancellationTokenSource? enrichCts;
    private CancellationTokenSource? portraitsCts;
    private string? preparedVisibleSignature;
    private long portraitRequestId;
    private const int PacingDelayMs = 250;

    [SupplyParameterFromQuery(Name = "sort")]
    public string? Sort { get; set; }

    [SupplyParameterFromQuery(Name = "page")]
    public int? Page { get; set; }

    [SupplyParameterFromQuery(Name = "redirect")]
    public string? RedirectPath { get; set; }

    private LoadingState<IReadOnlyList<CharacterDto>> state = new LoadingState<IReadOnlyList<CharacterDto>>.Idle();
    private bool loading;
    private Dictionary<string, string> portraits = [];
    private string? selectedCharacterId;
    private bool selecting;
    private string? selectError;
    private string deleteConfirmation = "";
    private string? deleteError;
    private bool deleting;

    private bool deleteConfirmationValid => deleteConfirmation == "FORGET ME";
    private static int ComponentPageSize => MobilePageSize;
    private string SortValue => IsNameSort ? NameSortValue : DefaultSortValue;
    private bool IsNameSort => string.Equals(Sort, NameSortValue, StringComparison.OrdinalIgnoreCase);
    private IReadOnlyList<CharacterDto> OrderedCharacters =>
        state is LoadingState<IReadOnlyList<CharacterDto>>.Success s
            ? IsNameSort
                ? s.Value.OrderBy(c => c.Name, StringComparer.OrdinalIgnoreCase).ToList()
                : s.Value
            : [];

    private int TotalPages => Math.Max(1, (int)Math.Ceiling(OrderedCharacters.Count / (double)ComponentPageSize));
    private int RequestedPage => Page.GetValueOrDefault(1) > 0 ? Page.GetValueOrDefault(1) : 1;
    private int CurrentPage => Math.Min(RequestedPage, TotalPages);
    private IReadOnlyList<CharacterDto> VisibleCharacters =>
        OrderedCharacters
            .Skip((CurrentPage - 1) * ComponentPageSize)
            .Take(ComponentPageSize)
            .ToList();

    private static readonly Dictionary<string, object> DeleteConfirmAttrs = new()
    {
        ["autocomplete"] = "off",
        ["autocapitalize"] = "characters",
        ["spellcheck"] = (bool?)false,
    };

    protected override async Task OnInitializedAsync()
    {
        var meTask = MeClient.GetAsync(CancellationToken.None);
        await LoadCharacters();
        var me = await meTask;
        selectedCharacterId = me?.SelectedCharacterId;

        await EnsureVisibleCardsPreparedAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        await EnsureVisibleCardsPreparedAsync();
    }

    private async Task LoadCharacters()
    {
        loading = true;
        state = new LoadingState<IReadOnlyList<CharacterDto>>.Loading();
        try
        {
            var result = await BattleNetClient.GetCharactersAsync(CancellationToken.None);
            switch (result)
            {
                case CharactersFetchResult.Cached cached:
                    ApplyCharacters(cached.Characters);
                    break;

                case CharactersFetchResult.NeedsRefresh:
                    // Backend has no cached profile (or cooldown expired) and asks
                    // us to fetch fresh from Blizzard.  Without this fallback, a
                    // first visit to /characters shows "load failed" until the
                    // user clicks the refresh button.
                    var fresh = await BattleNetClient.RefreshCharactersAsync(CancellationToken.None);
                    if (fresh is null)
                        state = new LoadingState<IReadOnlyList<CharacterDto>>.Failure(Loc["characters.error.loadFailed"]);
                    else
                        ApplyCharacters(fresh);
                    break;

                default:
                    state = new LoadingState<IReadOnlyList<CharacterDto>>.Failure(Loc["characters.error.loadFailed"]);
                    break;
            }
        }
        catch (Exception ex)
        {
            state = new LoadingState<IReadOnlyList<CharacterDto>>.Failure(ex.Message);
        }
        finally
        {
            loading = false;
        }
    }

    private void ApplyCharacters(IReadOnlyList<CharacterDto> chars)
    {
        state = new LoadingState<IReadOnlyList<CharacterDto>>.Success(chars);
        preparedVisibleSignature = null;
        cardState.Clear();
        ResetEnrichQueue();
        foreach (var c in chars)
            cardState[CharKey(c)] = (c.ClassId is not null && c.ActiveSpecId is not null)
                ? EnrichState.Enriched
                : EnrichState.Pending;
    }

    private async Task RefreshCharacters()
    {
        loading = true;
        state = new LoadingState<IReadOnlyList<CharacterDto>>.Loading();
        try
        {
            var chars = await BattleNetClient.RefreshCharactersAsync(CancellationToken.None);
            if (chars is null)
            {
                state = new LoadingState<IReadOnlyList<CharacterDto>>.Failure("Failed to refresh characters.");
            }
            else
            {
                portraits = [];
                ApplyCharacters(chars);
                await EnsureVisibleCardsPreparedAsync();
            }
        }
        catch (Exception ex)
        {
            state = new LoadingState<IReadOnlyList<CharacterDto>>.Failure(ex.Message);
        }
        finally
        {
            loading = false;
        }
    }

    private async Task EnsureVisibleCardsPreparedAsync()
    {
        if (state is not LoadingState<IReadOnlyList<CharacterDto>>.Success)
            return;

        var visible = VisibleCharacters;
        var signature = string.Join('|', visible.Select(CharKey));
        if (signature == preparedVisibleSignature)
            return;

        preparedVisibleSignature = signature;
        ResetEnrichQueue();
        var requestId = ++portraitRequestId;
        portraitsCts?.Cancel();
        portraitsCts = new CancellationTokenSource();
        _ = LoadPortraitsAsync(visible, signature, requestId, portraitsCts.Token);

        var pending = visible
            .Where(c => cardState.TryGetValue(CharKey(c), out var s) && s == EnrichState.Pending)
            .ToList();
        var eager = pending.Take(EagerEnrichCount).ToList();
        var remaining = pending.Skip(EagerEnrichCount).ToList();

        await Task.WhenAll(eager.Select(c => EnrichAsync(c)));
        EnqueueRemaining(remaining);
    }

    private void HandleSortChanged(string value)
    {
        Nav.NavigateTo(Nav.GetUriWithQueryParameters(new Dictionary<string, object?>
        {
            ["sort"] = string.Equals(value, NameSortValue, StringComparison.OrdinalIgnoreCase) ? NameSortValue : null,
            ["page"] = null,
        }), forceLoad: false);
    }

    private void HandlePageChange(int page)
    {
        Nav.NavigateTo(Nav.GetUriWithQueryParameter("page", page <= 1 ? null : page), forceLoad: false);
    }

    private async Task LoadPortraitsAsync(
        IReadOnlyList<CharacterDto> chars,
        string visibleSignature,
        long requestId,
        CancellationToken ct)
    {
        var requests = chars
            .Where(c => string.IsNullOrEmpty(c.PortraitUrl))
            .Select(c => new CharacterPortraitRequest(c.Region, c.Realm, c.Name))
            .ToList();

        if (requests.Count == 0)
            return;

        IDictionary<string, string>? result;
        try
        {
            result = await BattleNetClient.GetPortraitsAsync(requests, ct);
        }
        catch (OperationCanceledException) when (ct.IsCancellationRequested)
        {
            return;
        }

        if (ct.IsCancellationRequested
            || requestId != portraitRequestId
            || visibleSignature != preparedVisibleSignature)
        {
            return;
        }

        if (result is not null)
        {
            foreach (var kv in result)
                portraits[kv.Key] = kv.Value;
            StateHasChanged();
        }
    }

    private async Task HandleSelectCharacter(CharacterDto c)
    {
        var key = CharKey(c);
        if (key == selectedCharacterId || selecting) return;

        selectError = null;
        selecting = true;
        StateHasChanged();

        // Ensure enrichment before PUT.
        if (!cardState.TryGetValue(key, out var s)) s = EnrichState.Pending;
        switch (s)
        {
            case EnrichState.Enriching:
                if (inflightEnrich.TryGetValue(key, out var tcs)) await tcs.Task;
                break;
            case EnrichState.Pending:
                var wait = EnsureInflightEnrich(key);
                EnqueueFront(key);
                await wait.Task;
                break;
            case EnrichState.Failed:
                await EnrichAsync(c);
                break;
            case EnrichState.Enriched:
                break;
        }

        if (cardState[key] != EnrichState.Enriched)
        {
            selecting = false;
            selectError = Loc["characters.error.selectFailed"];
            StateHasChanged();
            return;
        }

        var prev = selectedCharacterId;
        selectedCharacterId = key;
        StateHasChanged();

        var ok = await MeClient.SelectCharacterAsync(key, CancellationToken.None);
        selecting = false;
        if (!ok)
        {
            selectedCharacterId = prev;
            selectError = Loc["characters.error.selectFailed"];
        }
        else
        {
            AuthStateRefresher.RefreshAuthenticationState();
            Nav.NavigateTo(SafeRedirectPath(), forceLoad: false);
        }
        StateHasChanged();
    }

    private async Task HandleDeleteAccount()
    {
        if (!deleteConfirmationValid || deleting)
            return;

        deleting = true;
        deleteError = null;
        try
        {
            var ok = await MeClient.DeleteAsync(CancellationToken.None);
            if (ok)
            {
                Nav.NavigateTo("/goodbye", forceLoad: false);
            }
            else
            {
                deleteError = Loc["characters.deleteAccount.failed"];
            }
        }
        catch
        {
            deleteError = Loc["characters.deleteAccount.error"];
        }
        finally
        {
            deleting = false;
        }
    }

    private void EnqueueRemaining(IEnumerable<CharacterDto> remaining)
    {
        foreach (var c in remaining)
            enrichQueue.Enqueue(CharKey(c));
        EnsureWorker();
    }

    private void EnqueueFront(string key)
    {
        // Promote: rebuild queue with key at front.
        var buf = new List<string> { key };
        while (enrichQueue.TryDequeue(out var k)) if (k != key) buf.Add(k);
        foreach (var k in buf) enrichQueue.Enqueue(k);
        EnsureWorker();
    }

    private void EnsureWorker()
    {
        if (enrichWorkerTask is { IsCompleted: false }) return;
        var cts = new CancellationTokenSource();
        enrichCts = cts;
        enrichWorkerTask = RunEnrichWorkerAsync(cts);
    }

    private async Task RunEnrichWorkerAsync(CancellationTokenSource cts)
    {
        var ct = cts.Token;
        try
        {
            while (!ct.IsCancellationRequested && enrichQueue.TryDequeue(out var key))
            {
                var character = VisibleCharacters.FirstOrDefault(c => CharKey(c) == key);
                if (character is null) continue;
                if (cardState.TryGetValue(key, out var s) && s != EnrichState.Pending) continue;
                await EnrichAsync(character);
                await Task.Delay(PacingDelayMs, ct);
            }
        }
        catch (OperationCanceledException) when (ct.IsCancellationRequested)
        {
        }
        finally
        {
            if (ReferenceEquals(enrichCts, cts))
            {
                enrichCts = null;
                enrichWorkerTask = null;
            }

            cts.Dispose();
        }
    }

    private void ResetEnrichQueue()
    {
        enrichQueue.Clear();
        enrichCts?.Cancel();
        enrichCts = null;
        enrichWorkerTask = null;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (state is LoadingState<IReadOnlyList<CharacterDto>>.Success && viewportModule is null)
        {
            viewportModule = await JS.InvokeAsync<IJSObjectReference>("import", "./js/viewport-observer.js");
            selfRef = DotNetObjectReference.Create(this);
            await viewportModule.InvokeVoidAsync("start", selfRef, "[data-char-id]");
        }
    }

    [JSInvokable]
    public void OnCardVisible(string id)
    {
        if (VisibleCharacters.Any(c => CharKey(c) == id)
            && cardState.TryGetValue(id, out var s)
            && s == EnrichState.Pending)
            EnqueueFront(id);
    }

    private string SafeRedirectPath()
    {
        if (string.IsNullOrWhiteSpace(RedirectPath)
            || !RedirectPath.StartsWith("/", StringComparison.Ordinal)
            || RedirectPath.StartsWith("//", StringComparison.Ordinal)
            || RedirectPath.Any(c => char.IsWhiteSpace(c) || char.IsControl(c)))
        {
            return "/runs";
        }

        return RedirectPath;
    }

    public async ValueTask DisposeAsync()
    {
        enrichCts?.Cancel();
        portraitsCts?.Cancel();
        if (viewportModule is not null && selfRef is not null)
        {
            try { await viewportModule.InvokeVoidAsync("stop", selfRef); } catch { }
            await viewportModule.DisposeAsync();
        }
        selfRef?.Dispose();
        portraitsCts?.Dispose();
    }

    private async Task EnrichAsync(CharacterDto c)
    {
        var key = CharKey(c);
        var completion = EnsureInflightEnrich(key);
        cardState[key] = EnrichState.Enriching;
        StateHasChanged();

        try
        {
            var dto = await MeClient.EnrichCharacterAsync(key, CancellationToken.None);
            if (dto is not null)
            {
                if (state is LoadingState<IReadOnlyList<CharacterDto>>.Success s)
                {
                    var updated = s.Value.Select(x => CharKey(x) == key ? dto : x).ToList();
                    state = new LoadingState<IReadOnlyList<CharacterDto>>.Success(updated);
                }
                cardState[key] = EnrichState.Enriched;
            }
            else
            {
                cardState[key] = EnrichState.Failed;
            }
        }
        finally
        {
            inflightEnrich.Remove(key);
            completion.TrySetResult();
            StateHasChanged();
        }
    }

    private TaskCompletionSource EnsureInflightEnrich(string key)
    {
        if (inflightEnrich.TryGetValue(key, out var tcs))
            return tcs;

        tcs = new TaskCompletionSource(TaskCreationOptions.RunContinuationsAsynchronously);
        inflightEnrich[key] = tcs;
        return tcs;
    }

    // Lowercases all three components so the key is identical to
    // RunsPage.CharacterId, MeClient.SelectCharacterAsync URL paths, and
    // CharacterPortraitService's normalized response keys (region/realm/name
    // are normalised to lowercase server-side). A mixed-case key here used
    // to silently miss the active-character badge (when SelectedCharacterId
    // came back from the server in lowercase) and the portrait dictionary
    // lookup (server returns lowercase-keyed entries).
    private static string CharKey(CharacterDto c) =>
        $"{c.Region.ToLowerInvariant()}-{c.Realm.ToLowerInvariant()}-{c.Name.ToLowerInvariant()}";
}
