@page "/runs"
@page "/runs/{RunId}"
@attribute [Authorize]
@using Lfm.App.Components
@using Lfm.App.Components.Runs
@using Lfm.App.Runs
@using Lfm.App.Services
@using Lfm.Contracts.Characters
@using Lfm.Contracts.Runs
@using Lfm.Contracts.Specializations
@inject IBattleNetClient BattleNetClient
@inject IMeClient MeClient
@inject IRunsClient RunsClient
@inject ISpecializationsClient SpecializationsClient
@inject NavigationManager Nav
@inject IStringLocalizer Loc

<PageTitle>@Loc["runs.title"]</PageTitle>

<FluentStack Orientation="Orientation.Vertical" VerticalGap="12">
    <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="12" Wrap="true" Style="align-items:center">
        <FluentLabel Typo="Typography.H1" Style="flex:1">@Loc["runs.title"]</FluentLabel>
        <FluentButton Appearance="Appearance.Accent" OnClick="@(() => Nav.NavigateTo("/runs/new"))">
            @Loc["runs.create"]
        </FluentButton>
        <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8" Style="align-items:center">
            <FluentButton Appearance="Appearance.Outline" OnClick="@RefreshRuns" Disabled="@_refreshing">
                @Loc["common.refresh"]
            </FluentButton>
            @if (_refreshing && state is LoadingState<IReadOnlyList<RunSummaryDto>>.Success)
            {
                <span class="runs-inline-spinner" role="status"
                      aria-label="@Loc["runs.refreshing"]" title="@Loc["runs.refreshing"]">
                    <FluentProgressRing Style="width:20px;height:20px" />
                </span>
            }
        </FluentStack>
    </FluentStack>

    @switch (state)
    {
        case LoadingState<IReadOnlyList<RunSummaryDto>>.Idle:
        case LoadingState<IReadOnlyList<RunSummaryDto>>.Loading:
            <div class="runs-loading" role="status" aria-live="polite" aria-label="@Loc["common.loading"]">
                <FluentProgressRing />
                <div class="runs-skeleton" aria-hidden="true">
                    @for (var i = 0; i < 5; i++)
                    {
                        <div class="run-skeleton"></div>
                    }
                </div>
            </div>
            break;

        case LoadingState<IReadOnlyList<RunSummaryDto>>.Failure f:
            <FluentMessageBar Intent="MessageIntent.Error">@f.Message</FluentMessageBar>
            break;

        case LoadingState<IReadOnlyList<RunSummaryDto>>.Success s:
            <div class="runs-layout">
                <div class="runs-sidebar">
                    @{
                        var groups = GroupRuns(s.Value, DateTimeOffset.UtcNow);
                        var pastCount = s.Value.Count(r =>
                            RunVisualization.GetHorizon(r.StartTime, DateTimeOffset.UtcNow) == TimeHorizon.Past);
                    }
                    @if (s.Value.Count == 0)
                    {
                        <FluentMessageBar Intent="MessageIntent.Info">
                            @Loc["runs.empty"]
                            <FluentAnchor Href="/runs/new">@Loc["runs.emptyCta"]</FluentAnchor>
                        </FluentMessageBar>
                    }
                    else
                    {
                        @foreach (var group in groups)
                        {
                            if (group.Horizon == TimeHorizon.Past && !_showPast)
                            {
                                continue;
                            }
                            <div class="runs-group" @key="group.Horizon">
                                <h2 class="runs-group__title">@HorizonLabel(group.Horizon)</h2>
                                @foreach (var run in group.Runs)
                                {
                                    var isSelected = run.Id == selectedRunId;
                                    <div @key="run.Id"
                                         class="run-list-card @(isSelected ? "run-list-card--selected" : null)"
                                         data-testid="run-card-@run.Id">
                                        <RunListItem Run="run"
                                                     IsSelected="@isSelected"
                                                     OnSelected="@SelectRun" />
                                        <button type="button"
                                                class="run-mobile-detail-toggle"
                                                data-testid="run-mobile-detail-toggle-@run.Id"
                                                aria-controls="run-detail-panel"
                                                aria-expanded="@(isSelected ? "true" : "false")"
                                                @onclick="@(() => ToggleRunDetails(run.Id))">
                                            @(isSelected ? Loc["runs.hideDetails"] : Loc["runs.showDetails"])
                                        </button>
                                    </div>
                                }
                            </div>
                        }
                        @if (pastCount > 0)
                        {
                            <button type="button" class="runs-past-toggle"
                                    aria-expanded="@(_showPast ? "true" : "false")"
                                    @onclick="@TogglePast">
                                @(_showPast ? Loc["runs.hidePast"] : Loc["runs.showPast", pastCount])
                            </button>
                        }
                    }
                    @if (!string.IsNullOrWhiteSpace(_loadMoreError))
                    {
                        <FluentMessageBar Class="runs-load-more-error" Intent="MessageIntent.Error">
                            @_loadMoreError
                        </FluentMessageBar>
                    }
                    @if (!string.IsNullOrEmpty(_continuationToken))
                    {
                        <FluentButton Appearance="Appearance.Outline"
                                      Class="runs-load-more"
                                      OnClick="@LoadMoreRuns"
                                      Disabled="@_loadingMore">
                            @(_loadingMore ? Loc["common.loading"] : Loc["runs.loadMore"])
                        </FluentButton>
                    }
                </div>

                <div id="run-detail-panel"
                     class="runs-detail @(selectedRun is null ? "runs-detail--empty" : "runs-detail--selected")"
                     data-testid="run-detail-panel">
                    @if (selectedRun != null)
                    {
                        var currentSignup = selectedRun.RunCharacters.FirstOrDefault(c => c.IsCurrentUser);
                        var attending = selectedRun.RunCharacters.Where(c => RunVisualization.IsAttending(c.ReviewedAttendance)).ToList();
                        var notAttending = selectedRun.RunCharacters.Where(c => c.ReviewedAttendance is "OUT" or "AWAY").ToList();

                        <div class="run-detail-stack">
                            <FluentCard>
                                <section class="run-detail-summary" data-testid="run-detail-summary">
                                    <div class="run-detail-header">
                                        <div class="run-detail-heading">
                                            <h2 class="run-detail-title">@RenderTitle(selectedRun.InstanceName)</h2>
                                            @if (!string.IsNullOrWhiteSpace(selectedRun.Description))
                                            {
                                                <p class="run-detail-description">@selectedRun.Description</p>
                                            }
                                        </div>
                                        <DifficultyPill Difficulty="@selectedRun.Difficulty" />
                                        <FluentButton Appearance="Appearance.Outline"
                                                      OnClick="@(() => Nav.NavigateTo($"/runs/{Uri.EscapeDataString(selectedRun.Id)}/edit"))"
                                                      Disabled="@IsSignupClosed(selectedRun.SignupCloseTime)">
                                            @Loc["runs.edit"]
                                        </FluentButton>
                                    </div>

                                    <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="16" Wrap="true" Class="run-detail-meta">
                                        <span><strong>@Loc["runs.start"]</strong> @FormatDate(selectedRun.StartTime)</span>
                                        <span><strong>@Loc["runs.signupCloses"]</strong> @FormatDate(selectedRun.SignupCloseTime)</span>
                                        <span><strong>@Loc["runs.guild"]</strong> @selectedRun.CreatorGuild</span>
                                    </FluentStack>
                                </section>
                            </FluentCard>

                            <section class="run-signup-surface" data-testid="run-signup-surface">
                                <RunSignupPanel RunId="@selectedRun.Id"
                                                CurrentSignup="@currentSignup"
                                                Characters="@_signupCharacters"
                                                SignupClosed="@IsSignupClosed(selectedRun.SignupCloseTime)"
                                                OptionsLoading="@_signupOptionsLoading"
                                                OptionsForbidden="@_signupOptionsForbidden"
                                                PreferredCharacterId="@_preferredSignupCharacterId"
                                                CurrentSpecIconUrl="@SpecIconUrlFor(currentSignup)"
                                                SignupError="@_signupError"
                                                SignupSubmitting="@_signupSubmitting"
                                                CancelSubmitting="@_cancelSubmitting"
                                                OnSignup="@SubmitSignup"
                                                OnCancelConfirmed="@CancelSignup"
                                                OnOptionsRequested="@EnsureSignupOptionsLoaded" />
                            </section>

                            <section class="run-roster @(selectedRun.RunCharacters.Count == 0 ? "run-roster--empty" : "")" data-testid="run-roster">
                                @if (selectedRun.RunCharacters.Count == 0)
                                {
                                    <h3 class="roster-section-title" data-testid="roster-attending-title">
                                        @Loc["runs.attendingSection"] (0)
                                    </h3>
                                    <div class="run-roster-empty">
                                        <FluentLabel>@Loc["runs.noSignups"]</FluentLabel>
                                    </div>
                                }
                                else
                                {
                                    @if (attending.Count > 0)
                                    {
                                        <h3 class="roster-section-title" data-testid="roster-attending-title">
                                            @Loc["runs.attendingSection"] (@attending.Count)
                                        </h3>
                                        <div class="roster-role-grid">
                                            @foreach (var (roleKey, roleLabel) in RoleColumns)
                                            {
                                                var roleChars = attending.Where(c => RunVisualization.NormalizeRole(c.Role) == roleKey).ToList();
                                                <div class="roster-role-column">
                                                    <h4 class="roster-role-column-title">@roleLabel (@roleChars.Count)</h4>
                                                    @foreach (var character in roleChars)
                                                    {
                                                        <CharacterRow @key="@(character.CharacterRealm + "/" + character.CharacterName)" Character="character" />
                                                    }
                                                </div>
                                            }
                                        </div>
                                    }

                                    @if (notAttending.Count > 0)
                                    {
                                        <h3 class="roster-section-title" data-testid="roster-not-attending-title">
                                            @Loc["runs.notAttendingSection"] (@notAttending.Count)
                                        </h3>
                                        <div class="roster-rows">
                                            @foreach (var character in notAttending)
                                            {
                                                <CharacterRow @key="@(character.CharacterRealm + "/" + character.CharacterName)" Character="character" />
                                            }
                                        </div>
                                    }
                                }
                            </section>
                        </div>
                    }
                    else
                    {
                        <FluentLabel>@Loc["runs.selectPrompt"]</FluentLabel>
                    }
                </div>
            </div>
            break;
    }
</FluentStack>

@code {
    [Parameter] public string? RunId { get; set; }

    private LoadingState<IReadOnlyList<RunSummaryDto>> state = new LoadingState<IReadOnlyList<RunSummaryDto>>.Idle();
    private bool _refreshing;
    private bool _loadingMore;
    private bool _showPast;
    private string? _continuationToken;
    private string? _loadMoreError;
    private string? selectedRunId;
    private RunDetailDto? selectedRun;
    private IReadOnlyList<CharacterDto> _signupCharacters = [];
    private bool _signupOptionsLoaded;
    private bool _signupOptionsLoading;
    private bool _signupOptionsForbidden;
    private string? _preferredSignupCharacterId;
    private string? _signupError;
    private bool _signupSubmitting;
    private bool _cancelSubmitting;
    private bool _specIconsLoaded;
    private bool _specIconsLoading;
    private IReadOnlyDictionary<int, string> _specIconUrls = new Dictionary<int, string>();

    private static readonly (string Key, string LocKey)[] RoleColumnKeys =
    [
        ("TANK", "runs.role.tank"),
        ("HEALER", "runs.role.healer"),
        ("DPS", "runs.role.dps"),
    ];

    private IEnumerable<(string Key, string Label)> RoleColumns =>
        RoleColumnKeys.Select(x => (x.Key, Loc[x.LocKey].Value));

    protected override async Task OnInitializedAsync()
    {
        selectedRunId = RunId;
        await LoadRuns(isRefresh: false);
    }

    protected override async Task OnParametersSetAsync()
    {
        if (RunId != selectedRunId)
        {
            selectedRunId = RunId;
            if (selectedRunId != null)
            {
                await LoadRunDetail(selectedRunId);
            }
            else
            {
                selectedRun = null;
            }
        }
    }

    private Task RefreshRuns() => LoadRuns(isRefresh: true);

    private async Task LoadRuns(bool isRefresh)
    {
        _refreshing = true;
        if (!isRefresh)
        {
            state = new LoadingState<IReadOnlyList<RunSummaryDto>>.Loading();
        }

        try
        {
            var page = await ListInitialRunsPageAsync();
            _continuationToken = page.ContinuationToken;
            _loadMoreError = null;
            state = new LoadingState<IReadOnlyList<RunSummaryDto>>.Success(page.Items);

            if (selectedRunId != null)
            {
                await LoadRunDetail(selectedRunId);
            }
        }
        catch (Exception ex)
        {
            // On refresh, keep the previously-loaded list visible rather than
            // dropping the user back to an error-only view; a transient
            // network blip shouldn't wipe the page they were already reading.
            if (!isRefresh)
            {
                state = new LoadingState<IReadOnlyList<RunSummaryDto>>.Failure(ex.Message);
            }
        }
        finally
        {
            _refreshing = false;
        }
    }

    private async Task<RunsListResponse> ListInitialRunsPageAsync()
    {
        var pageTask = RunsClient.ListPageAsync(null, CancellationToken.None);
        if (pageTask is not null)
        {
            var page = await pageTask;
            if (page is not null)
                return page;
        }

        // Backward-compatible guard for older test doubles or alternate
        // clients that still implement only the pre-pagination list method.
        var items = await RunsClient.ListAsync(CancellationToken.None);
        return new RunsListResponse(items, null);
    }

    private async Task LoadMoreRuns()
    {
        if (_loadingMore || string.IsNullOrEmpty(_continuationToken))
            return;

        _loadingMore = true;
        _loadMoreError = null;
        try
        {
            var page = await RunsClient.ListPageAsync(_continuationToken, CancellationToken.None);
            _continuationToken = page.ContinuationToken;
            if (state is LoadingState<IReadOnlyList<RunSummaryDto>>.Success s)
            {
                state = new LoadingState<IReadOnlyList<RunSummaryDto>>.Success(
                    s.Value.Concat(page.Items).ToList());
            }
        }
        catch (Exception ex)
        {
            _loadMoreError = ex.Message;
        }
        finally
        {
            _loadingMore = false;
        }
    }

    private async Task SelectRun(string id)
    {
        selectedRunId = id;
        Nav.NavigateTo($"/runs/{Uri.EscapeDataString(id)}", replace: true);
        await LoadRunDetail(id);
    }

    private async Task ToggleRunDetails(string id)
    {
        if (selectedRunId == id)
        {
            CollapseRunDetails();
            return;
        }

        await SelectRun(id);
    }

    private void CollapseRunDetails()
    {
        selectedRunId = null;
        selectedRun = null;
        _signupError = null;
        ResetSignupOptions();
        Nav.NavigateTo("/runs", replace: true);
    }

    private async Task LoadRunDetail(string id)
    {
        try
        {
            var detail = await RunsClient.GetAsync(id, CancellationToken.None);
            if (detail is null)
            {
                selectedRun = null;
                return;
            }

            if (selectedRun?.Id != detail.Id)
            {
                ResetSignupOptions();
            }

            ApplyRunDetail(detail);
            _signupError = null;
            if (HasCurrentUserSignup(detail))
            {
                await EnsureSpecIconsLoaded();
            }
            else if (!IsSignupClosed(detail.SignupCloseTime))
            {
                await EnsureSignupOptionsLoaded();
            }
        }
        catch
        {
            selectedRun = null;
        }
    }

    private async Task EnsureSignupOptionsLoaded()
    {
        if (_signupOptionsLoaded || _signupOptionsLoading)
            return;

        _signupOptionsLoading = true;
        _signupOptionsForbidden = false;
        _signupError = null;
        StateHasChanged();
        try
        {
            if (selectedRun is null)
                return;

            var runId = selectedRun.Id;
            var meTask = MeClient.GetAsync(CancellationToken.None);
            var charactersResult = await RunsClient.GetSignupOptionsAsync(runId, CancellationToken.None);
            var me = await meTask;
            _preferredSignupCharacterId = me?.SelectedCharacterId;

            if (charactersResult is CharactersFetchResult.Cached cached)
            {
                _signupCharacters = cached.Characters;
                _signupOptionsLoaded = true;
            }
            else if (charactersResult is CharactersFetchResult.NeedsRefresh)
            {
                var fresh = await BattleNetClient.RefreshCharactersAsync(CancellationToken.None);
                if (fresh is null)
                {
                    _signupCharacters = [];
                    _signupOptionsLoaded = true;
                    _signupError = Loc["runs.signup.charactersLoadFailed"].Value;
                }
                else
                {
                    var refreshedOptions = await RunsClient.GetSignupOptionsAsync(runId, CancellationToken.None);
                    if (refreshedOptions is CharactersFetchResult.Cached refreshedCached)
                    {
                        _signupCharacters = refreshedCached.Characters;
                        _signupOptionsLoaded = true;
                    }
                    else if (refreshedOptions is CharactersFetchResult.Forbidden)
                    {
                        _signupCharacters = [];
                        _signupOptionsLoaded = true;
                        _signupOptionsForbidden = true;
                    }
                    else
                    {
                        _signupCharacters = [];
                        _signupOptionsLoaded = true;
                        _signupError = Loc["runs.signup.charactersLoadFailed"].Value;
                    }
                }
            }
            else if (charactersResult is CharactersFetchResult.Forbidden)
            {
                _signupCharacters = [];
                _signupOptionsLoaded = true;
                _signupOptionsForbidden = true;
            }
            else
            {
                _signupCharacters = [];
                _signupOptionsLoaded = true;
                _signupError = Loc["runs.signup.charactersLoadFailed"].Value;
            }
        }
        catch
        {
            _signupCharacters = [];
            _signupError = Loc["runs.signup.charactersLoadFailed"].Value;
        }
        finally
        {
            _signupOptionsLoading = false;
        }
    }

    private void ResetSignupOptions()
    {
        _signupCharacters = [];
        _signupOptionsLoaded = false;
        _signupOptionsLoading = false;
        _signupOptionsForbidden = false;
        _preferredSignupCharacterId = null;
    }

    private async Task SubmitSignup(SignupRequest request)
    {
        if (selectedRun is null || _signupSubmitting || string.IsNullOrEmpty(request.CharacterId))
            return;

        _signupSubmitting = true;
        _signupError = null;
        try
        {
            var updated = await RunsClient.SignupAsync(selectedRun.Id, request, CancellationToken.None);
            if (updated is null)
            {
                _signupError = Loc["runs.signup.failed"].Value;
                return;
            }

            ApplyRunDetail(updated);
            if (HasCurrentUserSignup(updated))
            {
                await EnsureSpecIconsLoaded();
            }
        }
        catch
        {
            _signupError = Loc["runs.signup.failed"].Value;
        }
        finally
        {
            _signupSubmitting = false;
        }
    }

    private async Task EnsureSpecIconsLoaded()
    {
        if (_specIconsLoaded || _specIconsLoading)
            return;

        _specIconsLoading = true;
        try
        {
            var specializations = await SpecializationsClient.ListAsync(CancellationToken.None);
            _specIconUrls = specializations
                .Where(spec => !string.IsNullOrWhiteSpace(spec.IconUrl))
                .GroupBy(spec => spec.Id)
                .ToDictionary(group => group.Key, group => group.First().IconUrl!);
            _specIconsLoaded = true;
        }
        catch
        {
            _specIconUrls = new Dictionary<int, string>();
        }
        finally
        {
            _specIconsLoading = false;
        }
    }

    private async Task CancelSignup()
    {
        if (selectedRun is null || _cancelSubmitting)
            return;

        _cancelSubmitting = true;
        _signupError = null;
        try
        {
            var updated = await RunsClient.CancelSignupAsync(selectedRun.Id, CancellationToken.None);
            if (updated is null)
            {
                _signupError = Loc["runs.signup.cancelFailed"].Value;
                return;
            }

            ApplyRunDetail(updated);
            if (!IsSignupClosed(updated.SignupCloseTime))
            {
                await EnsureSignupOptionsLoaded();
            }
        }
        catch
        {
            _signupError = Loc["runs.signup.cancelFailed"].Value;
        }
        finally
        {
            _cancelSubmitting = false;
        }
    }

    private void ApplyRunDetail(RunDetailDto detail)
    {
        selectedRun = detail;
        if (state is not LoadingState<IReadOnlyList<RunSummaryDto>>.Success s)
            return;

        var updated = s.Value
            .Select(run => run.Id == detail.Id ? ToSummary(detail) : run)
            .ToList();
        state = new LoadingState<IReadOnlyList<RunSummaryDto>>.Success(updated);
    }

    private static RunSummaryDto ToSummary(RunDetailDto detail) =>
        new(
            Id: detail.Id,
            StartTime: detail.StartTime,
            SignupCloseTime: detail.SignupCloseTime,
            Description: detail.Description,
            Visibility: detail.Visibility,
            CreatorGuild: detail.CreatorGuild,
            InstanceId: detail.InstanceId,
            InstanceName: detail.InstanceName,
            RunCharacters: detail.RunCharacters,
            Difficulty: detail.Difficulty,
            Size: detail.Size,
            KeystoneLevel: detail.KeystoneLevel);

    private static bool HasCurrentUserSignup(RunDetailDto detail) =>
        detail.RunCharacters.Any(c => c.IsCurrentUser);

    private string? SpecIconUrlFor(RunCharacterDto? signup) =>
        signup?.SpecId is int specId && _specIconUrls.TryGetValue(specId, out var iconUrl)
            ? iconUrl
            : null;

    private void TogglePast() => _showPast = !_showPast;

    private string HorizonLabel(TimeHorizon horizon) => horizon switch
    {
        TimeHorizon.ThisWeek => Loc["runs.horizon.thisWeek"],
        TimeHorizon.NextWeek => Loc["runs.horizon.nextWeek"],
        TimeHorizon.Later => Loc["runs.horizon.later"],
        TimeHorizon.Past => Loc["runs.horizon.past"],
        _ => Loc["runs.horizon.unknown"],
    };

    // Mythic+ "any dungeon" runs carry no InstanceName; fall back to a
    // localized label so the detail heading isn't missing.
    private string RenderTitle(string? instanceName) =>
        string.IsNullOrEmpty(instanceName) ? Loc["runs.anyDungeon"].Value : instanceName;

    // Upcoming horizons ascending (soonest first); Past descending (most
    // recent first); Unknown tail-end so unparseable rows remain visible.
    private static readonly IReadOnlyList<TimeHorizon> HorizonOrder =
    [
        TimeHorizon.ThisWeek,
        TimeHorizon.NextWeek,
        TimeHorizon.Later,
        TimeHorizon.Past,
        TimeHorizon.Unknown,
    ];

    private sealed record RunGroup(TimeHorizon Horizon, IReadOnlyList<RunSummaryDto> Runs);

    private static IReadOnlyList<RunGroup> GroupRuns(
        IReadOnlyList<RunSummaryDto> runs,
        DateTimeOffset now)
    {
        var buckets = runs
            .GroupBy(r => RunVisualization.GetHorizon(r.StartTime, now))
            .ToDictionary(g => g.Key, g => g.ToList());

        var result = new List<RunGroup>(HorizonOrder.Count);
        foreach (var horizon in HorizonOrder)
        {
            if (!buckets.TryGetValue(horizon, out var bucket) || bucket.Count == 0)
            {
                continue;
            }
            bucket.Sort((a, b) =>
            {
                var at = ParseOrMax(a.StartTime);
                var bt = ParseOrMax(b.StartTime);
                return horizon == TimeHorizon.Past
                    ? bt.CompareTo(at)
                    : at.CompareTo(bt);
            });
            result.Add(new RunGroup(horizon, bucket));
        }
        return result;
    }

    private static DateTimeOffset ParseOrMax(string? iso)
    {
        return DateTimeOffset.TryParse(iso, System.Globalization.CultureInfo.InvariantCulture,
            System.Globalization.DateTimeStyles.RoundtripKind, out var v)
            ? v
            : DateTimeOffset.MaxValue;
    }

    private static string FormatDate(string? isoDate)
    {
        if (string.IsNullOrEmpty(isoDate)) return "\u2014";
        if (DateTimeOffset.TryParse(isoDate, out var dto))
            return dto.ToString("yyyy-MM-dd HH:mm", System.Globalization.CultureInfo.InvariantCulture);
        return isoDate;
    }

    private static bool IsSignupClosed(string? signupCloseTime)
    {
        if (string.IsNullOrEmpty(signupCloseTime)) return false;
        return DateTimeOffset.TryParse(signupCloseTime, out var closeTime) && closeTime < DateTimeOffset.UtcNow;
    }

}
