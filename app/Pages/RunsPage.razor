@page "/runs"
@page "/runs/{RunId}"
@attribute [Authorize]
@using Lfm.App.Components
@using Lfm.App.Runs
@using Lfm.App.Services
@using Lfm.Contracts.Runs
@inject IRunsClient RunsClient
@inject NavigationManager Nav
@inject IStringLocalizer Loc

<PageTitle>@Loc["runs.title"]</PageTitle>

<FluentStack Orientation="Orientation.Vertical" VerticalGap="12">
    <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="12" Wrap="true" Style="align-items:center">
        <FluentLabel Typo="Typography.H1" Style="flex:1">@Loc["runs.title"]</FluentLabel>
        <FluentButton Appearance="Appearance.Accent" OnClick="@(() => Nav.NavigateTo("/runs/new"))">
            @Loc["runs.create"]
        </FluentButton>
        <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8" Style="align-items:center">
            <FluentButton Appearance="Appearance.Outline" OnClick="@RefreshRuns" Disabled="@_refreshing">
                @Loc["common.refresh"]
            </FluentButton>
            @if (_refreshing && state is LoadingState<IReadOnlyList<RunSummaryDto>>.Success)
            {
                <span class="runs-inline-spinner" role="status"
                      aria-label="@Loc["runs.refreshing"]" title="@Loc["runs.refreshing"]">
                    <FluentProgressRing Style="width:20px;height:20px" />
                </span>
            }
        </FluentStack>
    </FluentStack>

    @switch (state)
    {
        case LoadingState<IReadOnlyList<RunSummaryDto>>.Idle:
        case LoadingState<IReadOnlyList<RunSummaryDto>>.Loading:
            <div class="runs-loading" role="status" aria-live="polite" aria-label="@Loc["common.loading"]">
                <FluentProgressRing />
                <div class="runs-skeleton" aria-hidden="true">
                    @for (var i = 0; i < 5; i++)
                    {
                        <div class="run-skeleton"></div>
                    }
                </div>
            </div>
            break;

        case LoadingState<IReadOnlyList<RunSummaryDto>>.Failure f:
            <FluentMessageBar Intent="MessageIntent.Error">@f.Message</FluentMessageBar>
            break;

        case LoadingState<IReadOnlyList<RunSummaryDto>>.Success s when s.Value.Count == 0:
            <FluentMessageBar Intent="MessageIntent.Info">
                @Loc["runs.empty"]
                <FluentAnchor Href="/runs/new">@Loc["runs.emptyCta"]</FluentAnchor>
            </FluentMessageBar>
            break;

        case LoadingState<IReadOnlyList<RunSummaryDto>>.Success s:
            <div class="runs-layout">
                <div class="runs-sidebar">
                    @{
                        var groups = GroupRuns(s.Value, DateTimeOffset.UtcNow);
                        var pastCount = s.Value.Count(r =>
                            RunVisualization.GetHorizon(r.StartTime, DateTimeOffset.UtcNow) == TimeHorizon.Past);
                    }
                    @foreach (var group in groups)
                    {
                        if (group.Horizon == TimeHorizon.Past && !_showPast)
                        {
                            continue;
                        }
                        <div class="runs-group" @key="group.Horizon">
                            <h2 class="runs-group__title">@HorizonLabel(group.Horizon)</h2>
                            @foreach (var run in group.Runs)
                            {
                                <RunListItem @key="run.Id"
                                             Run="run"
                                             IsSelected="@(run.Id == selectedRunId)"
                                             OnSelected="@SelectRun" />
                            }
                        </div>
                    }
                    @if (pastCount > 0)
                    {
                        <button type="button" class="runs-past-toggle"
                                aria-expanded="@(_showPast ? "true" : "false")"
                                @onclick="@TogglePast">
                            @(_showPast ? Loc["runs.hidePast"] : Loc["runs.showPast", pastCount])
                        </button>
                    }
                </div>

                <div class="runs-detail">
                    @if (selectedRun != null)
                    {
                        <FluentCard>
                            <FluentStack Orientation="Orientation.Vertical" VerticalGap="12">
                                <div class="run-detail-header">
                                    <div class="run-detail-heading">
                                        <h2 class="run-detail-title">@selectedRun.InstanceName</h2>
                                        @if (!string.IsNullOrWhiteSpace(selectedRun.Description))
                                        {
                                            <p class="run-detail-description">@selectedRun.Description</p>
                                        }
                                    </div>
                                    <DifficultyPill Difficulty="@selectedRun.Difficulty" />
                                    <FluentButton Appearance="Appearance.Outline"
                                                  OnClick="@(() => Nav.NavigateTo($"/runs/{Uri.EscapeDataString(selectedRun.Id)}/edit"))"
                                                  Disabled="@IsSignupClosed(selectedRun.SignupCloseTime)">
                                        @Loc["runs.edit"]
                                    </FluentButton>
                                </div>

                                <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="16" Wrap="true" Class="run-detail-meta">
                                    <span><strong>@Loc["runs.start"]</strong> @FormatDate(selectedRun.StartTime)</span>
                                    <span><strong>@Loc["runs.signupCloses"]</strong> @FormatDate(selectedRun.SignupCloseTime)</span>
                                    <span><strong>@Loc["runs.visibility"]</strong> @selectedRun.Visibility</span>
                                    <span><strong>@Loc["runs.guild"]</strong> @selectedRun.CreatorGuild</span>
                                </FluentStack>

                                @{
                                    var attending = selectedRun.RunCharacters.Where(c => RunVisualization.IsAttending(c.ReviewedAttendance)).ToList();
                                    var notAttending = selectedRun.RunCharacters.Where(c => c.ReviewedAttendance is "OUT" or "AWAY").ToList();
                                }

                                @if (selectedRun.RunCharacters.Count == 0)
                                {
                                    <FluentLabel>@Loc["runs.noSignups"]</FluentLabel>
                                }
                                else
                                {
                                    @if (attending.Count > 0)
                                    {
                                        <h3 class="roster-section-title" data-testid="roster-attending-title">
                                            @Loc["runs.attendingSection"] (@attending.Count)
                                        </h3>
                                        <div class="roster-role-grid">
                                            @foreach (var (roleKey, roleLabel) in RoleColumns)
                                            {
                                                var roleChars = attending.Where(c => RunVisualization.NormalizeRole(c.Role) == roleKey).ToList();
                                                <div class="roster-role-column">
                                                    <h4 class="roster-role-column-title">@roleLabel (@roleChars.Count)</h4>
                                                    @foreach (var character in roleChars)
                                                    {
                                                        <CharacterRow @key="@(character.CharacterRealm + "/" + character.CharacterName)" Character="character" />
                                                    }
                                                </div>
                                            }
                                        </div>
                                    }

                                    @if (notAttending.Count > 0)
                                    {
                                        <h3 class="roster-section-title" data-testid="roster-not-attending-title">
                                            @Loc["runs.notAttendingSection"] (@notAttending.Count)
                                        </h3>
                                        <div class="roster-rows">
                                            @foreach (var character in notAttending)
                                            {
                                                <CharacterRow @key="@(character.CharacterRealm + "/" + character.CharacterName)" Character="character" />
                                            }
                                        </div>
                                    }
                                }
                            </FluentStack>
                        </FluentCard>
                    }
                    else
                    {
                        <FluentLabel>@Loc["runs.selectPrompt"]</FluentLabel>
                    }
                </div>
            </div>
            break;
    }
</FluentStack>

@code {
    [Parameter] public string? RunId { get; set; }

    private LoadingState<IReadOnlyList<RunSummaryDto>> state = new LoadingState<IReadOnlyList<RunSummaryDto>>.Idle();
    private bool _refreshing;
    private bool _showPast;
    private string? selectedRunId;
    private RunDetailDto? selectedRun;

    private static readonly (string Key, string LocKey)[] RoleColumnKeys =
    [
        ("TANK", "runs.role.tank"),
        ("HEALER", "runs.role.healer"),
        ("DPS", "runs.role.dps"),
    ];

    private IEnumerable<(string Key, string Label)> RoleColumns =>
        RoleColumnKeys.Select(x => (x.Key, Loc[x.LocKey].Value));

    protected override async Task OnInitializedAsync()
    {
        selectedRunId = RunId;
        await LoadRuns(isRefresh: false);
    }

    protected override async Task OnParametersSetAsync()
    {
        if (RunId != selectedRunId)
        {
            selectedRunId = RunId;
            if (selectedRunId != null)
            {
                await LoadRunDetail(selectedRunId);
            }
            else
            {
                selectedRun = null;
            }
        }
    }

    private Task RefreshRuns() => LoadRuns(isRefresh: true);

    private async Task LoadRuns(bool isRefresh)
    {
        _refreshing = true;
        if (!isRefresh)
        {
            state = new LoadingState<IReadOnlyList<RunSummaryDto>>.Loading();
        }

        try
        {
            var items = await RunsClient.ListAsync(CancellationToken.None);
            state = new LoadingState<IReadOnlyList<RunSummaryDto>>.Success(items);

            if (selectedRunId != null)
            {
                await LoadRunDetail(selectedRunId);
            }
        }
        catch (Exception ex)
        {
            // On refresh, keep the previously-loaded list visible rather than
            // dropping the user back to an error-only view; a transient
            // network blip shouldn't wipe the page they were already reading.
            if (!isRefresh)
            {
                state = new LoadingState<IReadOnlyList<RunSummaryDto>>.Failure(ex.Message);
            }
        }
        finally
        {
            _refreshing = false;
        }
    }

    private async Task SelectRun(string id)
    {
        selectedRunId = id;
        Nav.NavigateTo($"/runs/{Uri.EscapeDataString(id)}", replace: true);
        await LoadRunDetail(id);
    }

    private async Task LoadRunDetail(string id)
    {
        try
        {
            selectedRun = await RunsClient.GetAsync(id, CancellationToken.None);
        }
        catch
        {
            selectedRun = null;
        }
    }

    private void TogglePast() => _showPast = !_showPast;

    private string HorizonLabel(TimeHorizon horizon) => horizon switch
    {
        TimeHorizon.ThisWeek => Loc["runs.horizon.thisWeek"],
        TimeHorizon.NextWeek => Loc["runs.horizon.nextWeek"],
        TimeHorizon.Later => Loc["runs.horizon.later"],
        TimeHorizon.Past => Loc["runs.horizon.past"],
        _ => Loc["runs.horizon.unknown"],
    };

    // Upcoming horizons ascending (soonest first); Past descending (most
    // recent first); Unknown tail-end so unparseable rows remain visible.
    private static readonly IReadOnlyList<TimeHorizon> HorizonOrder =
    [
        TimeHorizon.ThisWeek,
        TimeHorizon.NextWeek,
        TimeHorizon.Later,
        TimeHorizon.Past,
        TimeHorizon.Unknown,
    ];

    private sealed record RunGroup(TimeHorizon Horizon, IReadOnlyList<RunSummaryDto> Runs);

    private static IReadOnlyList<RunGroup> GroupRuns(
        IReadOnlyList<RunSummaryDto> runs,
        DateTimeOffset now)
    {
        var buckets = runs
            .GroupBy(r => RunVisualization.GetHorizon(r.StartTime, now))
            .ToDictionary(g => g.Key, g => g.ToList());

        var result = new List<RunGroup>(HorizonOrder.Count);
        foreach (var horizon in HorizonOrder)
        {
            if (!buckets.TryGetValue(horizon, out var bucket) || bucket.Count == 0)
            {
                continue;
            }
            bucket.Sort((a, b) =>
            {
                var at = ParseOrMax(a.StartTime);
                var bt = ParseOrMax(b.StartTime);
                return horizon == TimeHorizon.Past
                    ? bt.CompareTo(at)
                    : at.CompareTo(bt);
            });
            result.Add(new RunGroup(horizon, bucket));
        }
        return result;
    }

    private static DateTimeOffset ParseOrMax(string? iso)
    {
        return DateTimeOffset.TryParse(iso, System.Globalization.CultureInfo.InvariantCulture,
            System.Globalization.DateTimeStyles.RoundtripKind, out var v)
            ? v
            : DateTimeOffset.MaxValue;
    }

    private static string FormatDate(string? isoDate)
    {
        if (string.IsNullOrEmpty(isoDate)) return "\u2014";
        if (DateTimeOffset.TryParse(isoDate, out var dto))
            return dto.ToString("yyyy-MM-dd HH:mm", System.Globalization.CultureInfo.InvariantCulture);
        return isoDate;
    }

    private static bool IsSignupClosed(string? signupCloseTime)
    {
        if (string.IsNullOrEmpty(signupCloseTime)) return false;
        return DateTimeOffset.TryParse(signupCloseTime, out var closeTime) && closeTime < DateTimeOffset.UtcNow;
    }
}
