@page "/guild"
@using Lfm.App.Services
@using Lfm.Contracts.Guild
@attribute [Authorize]
@inject IGuildClient GuildClient
@inject ToastHelper Toast
@inject IStringLocalizer Loc
@inject UnsavedChangesGuard UnsavedGuard
@implements IAsyncDisposable

<PageTitle>@Loc["guild.title"]</PageTitle>

<FluentStack Orientation="Orientation.Vertical" VerticalGap="12">
    <FluentLabel Typo="Typography.H1">@Loc["guild.title"]</FluentLabel>

    @if (ShowSetupExplanation)
    {
        <FluentMessageBar Intent="MessageIntent.Info">@Loc["guild.setupRequiredExplanation"]</FluentMessageBar>
    }

    @switch (state)
    {
        case LoadingState<GuildDto>.Idle:
        case LoadingState<GuildDto>.Loading:
            <FluentProgressRing />
            break;
        case LoadingState<GuildDto>.Failure f:
            <FluentMessageBar Intent="MessageIntent.Error">@f.Message</FluentMessageBar>
            break;
        case LoadingState<GuildDto>.Success s:
            @RenderGuild(s.Value)
            break;
    }
</FluentStack>

@if (UnsavedGuard.IsConfirmationVisible)
{
    <ConfirmDialog Open="true"
                   Title="@Loc["unsavedChanges.title"]"
                   Body="@Loc["unsavedChanges.body"]"
                   ConfirmText="@Loc["unsavedChanges.leave"]"
                   CancelText="@Loc["unsavedChanges.stay"]"
                   OnConfirm="@UnsavedGuard.ConfirmLeaveAsync"
                   OnCancel="@UnsavedGuard.StayAsync" />
}

@code {
    private LoadingState<GuildDto> state = new LoadingState<GuildDto>.Idle();
    private bool saving;
    private GuildSettingsSnapshot? savedSettingsSnapshot;
    private UnsavedChangesGuard.Registration? unsavedChangesRegistration;

    private string draftTimezone = "Europe/Helsinki";
    private string draftLocale = "fi";
    private string draftSlogan = string.Empty;
    private IReadOnlyList<UpdateGuildRankPermission> draftPermissions = [];

    [SupplyParameterFromQuery(Name = "setup")]
    public string? Setup { get; set; }

    private bool ShowSetupExplanation =>
        Setup == "required"
        && (state is not LoadingState<GuildDto>.Success s || s.Value.Setup.RequiresSetup);

    protected override async Task OnInitializedAsync()
    {
        state = new LoadingState<GuildDto>.Loading();
        try
        {
            var dto = await GuildClient.GetAsync(CancellationToken.None);
            if (dto is null)
            {
                state = new LoadingState<GuildDto>.Failure(Loc["guild.error.loadFailed"]);
            }
            else
            {
                ApplyGuildData(dto);
                state = new LoadingState<GuildDto>.Success(dto);
                if (dto.Editor.CanEdit)
                {
                    RegisterUnsavedChangesGuard();
                }
            }
        }
        catch (Exception ex)
        {
            state = new LoadingState<GuildDto>.Failure(ex.Message);
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (unsavedChangesRegistration is not null)
        {
            await UnsavedGuard.RefreshAsync();
        }
    }

    private void ApplyGuildData(GuildDto dto)
    {
        draftTimezone = dto.Setup.Timezone;
        draftLocale = dto.Setup.Locale;
        draftSlogan = dto.Guild?.Slogan ?? string.Empty;
        draftPermissions = dto.Settings?.RankPermissions
            .Select(p => new UpdateGuildRankPermission(p.Rank, p.CanCreateGuildRuns, p.CanSignupGuildRuns, p.CanDeleteGuildRuns))
            .ToList()
            ?? [];
    }

    private RenderFragment RenderGuild(GuildDto dto) => __builder =>
    {
        if (dto.Guild is null)
        {
            <FluentCard>
                <FluentStack Orientation="Orientation.Vertical" VerticalGap="8">
                    <FluentLabel Typo="Typography.H4">@Loc["guild.noGuild.title"]</FluentLabel>
                    <FluentLabel>@Loc["guild.noGuild.body"]</FluentLabel>
                </FluentStack>
            </FluentCard>
        }
        else
        {
            <FluentStack Orientation="Orientation.Vertical" VerticalGap="16">
                <FluentCard>
                    <FluentStack Orientation="Orientation.Vertical" VerticalGap="8">
                        <FluentLabel Typo="Typography.H4">@dto.Guild.Name</FluentLabel>
                        @if (!string.IsNullOrEmpty(dto.Guild.Slogan))
                        {
                            <FluentLabel>@dto.Guild.Slogan</FluentLabel>
                        }
                        <FluentLabel>@dto.Guild.RealmName@(dto.Guild.FactionName != null ? $" \u00b7 {dto.Guild.FactionName}" : "")</FluentLabel>
                        @if (dto.Guild.CrestEmblemUrl != null)
                        {
                            <img src="@dto.Guild.CrestEmblemUrl"
                                 alt="@Loc["guild.crestAlt"]"
                                 class="guild-crest"
                                 width="88"
                                 height="88"
                                 loading="lazy"
                                 decoding="async" />
                        }
                        <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8" Wrap="true">
                            @StatusChip(dto.Setup.IsInitialized ? Loc["guild.chip.settingsLive"] : Loc["guild.chip.settingsPending"])
                            @StatusChip(dto.Editor.CanEdit ? Loc["guild.chip.editable"] : Loc["guild.chip.readOnly"])
                            @StatusChip(dto.Setup.RankDataFresh ? Loc["guild.chip.rankSyncFresh"] : Loc["guild.chip.rankSyncStale"])
                            @if (dto.Guild.MemberCount.HasValue)
                            {
                                @StatusChip(Loc["guild.chip.members", dto.Guild.MemberCount.Value])
                            }
                            @if (dto.Guild.RankCount.HasValue)
                            {
                                @StatusChip(Loc["guild.chip.ranksDetected", dto.Guild.RankCount.Value])
                            }
                        </FluentStack>
                    </FluentStack>
                </FluentCard>

                <FluentCard>
                    <FluentStack Orientation="Orientation.Vertical" VerticalGap="12">
                        <FluentLabel Typo="Typography.H4">@Loc["guild.status"]</FluentLabel>
                        <FluentLabel>@Loc["guild.timezone"] @dto.Setup.Timezone</FluentLabel>
                        <FluentLabel>@Loc["guild.locale"] @dto.Setup.Locale</FluentLabel>

                        @if (dto.Editor.CanEdit)
                        {
                            @if (dto.Setup.RequiresSetup)
                            {
                                <FluentMessageBar Intent="MessageIntent.Warning">@Loc["guild.setupRequired"]</FluentMessageBar>
                            }
                            @if (!dto.Setup.RankDataFresh)
                            {
                                <FluentMessageBar Intent="MessageIntent.Error">@Loc["guild.rankSyncStale"]</FluentMessageBar>
                            }

                            <GuildSettingsEditor
                                Timezone="@draftTimezone"
                                TimezoneChanged="@(v => draftTimezone = v)"
                                Locale="@draftLocale"
                                LocaleChanged="@(v => draftLocale = v)"
                                Slogan="@draftSlogan"
                                SloganChanged="@(v => draftSlogan = v)"
                                RankPermissions="@draftPermissions"
                                OnPermissionChange="@HandlePermissionChange"
                                Saving="@saving"
                                RankDataFresh="@dto.Setup.RankDataFresh"
                                OnSave="@HandleSave" />
                        }
                        else
                        {
                            <FluentLabel Typo="Typography.H4">@Loc["guild.yourAccess"]</FluentLabel>
                            <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8" Wrap="true">
                                @StatusChip(dto.MemberPermissions.CanCreateGuildRuns ? Loc["guild.chip.canCreate"] : Loc["guild.chip.cannotCreate"])
                                @StatusChip(dto.MemberPermissions.CanSignupGuildRuns ? Loc["guild.chip.canSignup"] : Loc["guild.chip.cannotSignup"])
                            </FluentStack>
                        }
                    </FluentStack>
                </FluentCard>
            </FluentStack>
        }
    };

    private static RenderFragment StatusChip(string label) => __builder =>
    {
        <span style="display:inline-flex;align-items:center;border:1px solid var(--neutral-stroke-rest);border-radius:999px;padding:2px 10px;min-height:28px">
            @label
        </span>
    };

    private void HandlePermissionChange((int Rank, string Field, bool Checked) args)
    {
        draftPermissions = draftPermissions
            .Select(p => p.Rank != args.Rank ? p : p with
            {
                CanCreateGuildRuns = args.Field == "canCreateGuildRuns" ? args.Checked : p.CanCreateGuildRuns,
                CanSignupGuildRuns = args.Field == "canSignupGuildRuns" ? args.Checked : p.CanSignupGuildRuns,
                CanDeleteGuildRuns = args.Field == "canDeleteGuildRuns" ? args.Checked : p.CanDeleteGuildRuns,
            })
            .ToList();
    }

    private async Task HandleSave()
    {
        saving = true;

        try
        {
            var request = new UpdateGuildRequest(draftTimezone, draftLocale, draftSlogan, draftPermissions);
            var updated = await GuildClient.UpdateAsync(request, CancellationToken.None);
            if (updated is null)
            {
                Toast.ShowError(Loc["guild.settingsSaveFailed"]);
            }
            else
            {
                ApplyGuildData(updated);
                state = new LoadingState<GuildDto>.Success(updated);
                savedSettingsSnapshot = CurrentSettingsSnapshot();
                await UnsavedGuard.RefreshAsync();
                Toast.ShowSuccess(Loc["guild.settingsSaved"]);
            }
        }
        catch
        {
            Toast.ShowError(Loc["guild.settingsSaveFailed"]);
        }
        finally
        {
            saving = false;
        }
    }

    private void RegisterUnsavedChangesGuard()
    {
        savedSettingsSnapshot = CurrentSettingsSnapshot();
        UnsavedGuard.StateChanged += HandleUnsavedChangesStateChanged;
        unsavedChangesRegistration = UnsavedGuard.Register(this, HasUnsavedChanges);
    }

    private bool HasUnsavedChanges() =>
        !saving
        && savedSettingsSnapshot is not null
        && CurrentSettingsSnapshot() != savedSettingsSnapshot;

    private GuildSettingsSnapshot CurrentSettingsSnapshot() =>
        new(
            draftTimezone,
            draftLocale,
            draftSlogan,
            string.Join('|', draftPermissions
                .OrderBy(p => p.Rank)
                .Select(p => $"{p.Rank}:{p.CanCreateGuildRuns}:{p.CanSignupGuildRuns}:{p.CanDeleteGuildRuns}")));

    private void HandleUnsavedChangesStateChanged() => _ = InvokeAsync(StateHasChanged);

    private async ValueTask DisposeUnsavedChangesGuardAsync()
    {
        UnsavedGuard.StateChanged -= HandleUnsavedChangesStateChanged;
        if (unsavedChangesRegistration is not null)
        {
            await unsavedChangesRegistration.DisposeAsync();
            unsavedChangesRegistration = null;
        }
    }

    public async ValueTask DisposeAsync() => await DisposeUnsavedChangesGuardAsync();

    private sealed record GuildSettingsSnapshot(
        string Timezone,
        string Locale,
        string Slogan,
        string RankPermissions);
}
