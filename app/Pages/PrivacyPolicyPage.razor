@page "/privacy"

<PageTitle>Privacy Policy — LFM</PageTitle>

<FluentStack Orientation="Orientation.Vertical" VerticalGap="24">
    <FluentStack Orientation="Orientation.Vertical" VerticalGap="4">
        <FluentLabel Typo="Typography.H2">Privacy Policy</FluentLabel>
        <FluentLabel>Last updated: April 2025</FluentLabel>
    </FluentStack>

    <FluentStack Orientation="Orientation.Vertical" VerticalGap="8">
        <FluentLabel Typo="Typography.H4">Data Controller</FluentLabel>
        <FluentLabel>This application is operated by the guild master of the associated World of Warcraft guild. You can contact us via the privacy contact form.</FluentLabel>
    </FluentStack>

    <FluentStack Orientation="Orientation.Vertical" VerticalGap="8">
        <FluentLabel Typo="Typography.H4">Data We Collect</FluentLabel>
        <FluentLabel>We collect your Battle.net account identifier, your World of Warcraft character names and realm, and your locale preference. No payment data is collected.</FluentLabel>
    </FluentStack>

    <FluentStack Orientation="Orientation.Vertical" VerticalGap="8">
        <FluentLabel Typo="Typography.H4">Cookies</FluentLabel>
        <FluentLabel>We use a single session cookie to keep you logged in. No third-party tracking cookies are used.</FluentLabel>
    </FluentStack>

    <FluentStack Orientation="Orientation.Vertical" VerticalGap="8">
        <FluentLabel Typo="Typography.H4">Third Parties</FluentLabel>
        <FluentLabel>We use Blizzard Entertainment's Battle.net OAuth service for authentication. No personal data is sold or shared with other third parties.</FluentLabel>
    </FluentStack>

    <FluentStack Orientation="Orientation.Vertical" VerticalGap="8">
        <FluentLabel Typo="Typography.H4">Retention</FluentLabel>
        <FluentLabel>Your data is retained for as long as your account exists. You can delete your account at any time from the Characters page, which will remove all personal data immediately.</FluentLabel>
    </FluentStack>

    <FluentStack Orientation="Orientation.Vertical" VerticalGap="8">
        <FluentLabel Typo="Typography.H4">Your Rights</FluentLabel>
        <FluentLabel>You have the right to access, rectify, and erase your personal data. Contact us using the privacy contact form to exercise these rights.</FluentLabel>
    </FluentStack>

    <FluentStack Orientation="Orientation.Vertical" VerticalGap="8">
        <FluentLabel Typo="Typography.H4">Contact</FluentLabel>
        <FluentLabel>For privacy-related enquiries, please use the contact form linked in the application footer.</FluentLabel>
    </FluentStack>
</FluentStack>

<!-- Honeypot: invisible decoy to divert email scrapers -->
<a href="mailto:contact@example.com"
   aria-hidden="true"
   tabindex="-1"
   style="position: absolute; left: -9999px; opacity: 0; pointer-events: none;">
    contact@example.com
</a>
