@page "/privacy"
@inject IHttpClientFactory HttpFactory
@inject IStringLocalizer Loc

<PageTitle>@Loc["privacy.title"] — @Loc["nav.logo"]</PageTitle>

@* Response-header X-Robots-Tag lives in wwwroot/staticwebapp.config.json.template,
   this <meta> is the same signal inside the rendered page so a crawler that only
   inspects HTML still sees the instruction. *@
<HeadContent>
    <meta name="robots" content="noindex, nofollow" />
</HeadContent>

<FluentStack Orientation="Orientation.Vertical" VerticalGap="24">
    <FluentStack Orientation="Orientation.Vertical" VerticalGap="4">
        <FluentLabel Typo="Typography.H1">@Loc["privacy.title"]</FluentLabel>
        <FluentLabel>@Loc["privacy.lastUpdated"]</FluentLabel>
    </FluentStack>

    <FluentStack Orientation="Orientation.Vertical" VerticalGap="8">
        <FluentLabel Typo="Typography.H4">@Loc["privacy.controller.heading"]</FluentLabel>
        <FluentLabel>@Loc["privacy.controller.body"]</FluentLabel>
    </FluentStack>

    <FluentStack Orientation="Orientation.Vertical" VerticalGap="8">
        <FluentLabel Typo="Typography.H4">@Loc["privacy.data.heading"]</FluentLabel>
        <FluentLabel>@Loc["privacy.data.body"]</FluentLabel>
    </FluentStack>

    <FluentStack Orientation="Orientation.Vertical" VerticalGap="8">
        <FluentLabel Typo="Typography.H4">@Loc["privacy.cookies.heading"]</FluentLabel>
        <FluentLabel>@Loc["privacy.cookies.body"]</FluentLabel>
    </FluentStack>

    <FluentStack Orientation="Orientation.Vertical" VerticalGap="8">
        <FluentLabel Typo="Typography.H4">@Loc["privacy.thirdParty.heading"]</FluentLabel>
        <FluentLabel>@Loc["privacy.thirdParty.body"]</FluentLabel>
    </FluentStack>

    <FluentStack Orientation="Orientation.Vertical" VerticalGap="8">
        <FluentLabel Typo="Typography.H4">@Loc["privacy.retention.heading"]</FluentLabel>
        <FluentLabel>@Loc["privacy.retention.body"]</FluentLabel>
    </FluentStack>

    <FluentStack Orientation="Orientation.Vertical" VerticalGap="8">
        <FluentLabel Typo="Typography.H4">@Loc["privacy.rights.heading"]</FluentLabel>
        <FluentLabel>@Loc["privacy.rights.body"]</FluentLabel>
    </FluentStack>

    @* Click-to-reveal: the email is never in the static HTML and never fetched
       until the user explicitly clicks. A crawler walking the rendered page —
       even one that executes Blazor's OnInitialized — never sees the address. *@
    <FluentStack Orientation="Orientation.Vertical" VerticalGap="8">
        <FluentLabel Typo="Typography.H4">@Loc["privacy.contact.heading"]</FluentLabel>
        <FluentLabel>@Loc["privacy.contact.body"]</FluentLabel>
        @switch (_state)
        {
            case RevealState.Idle:
                <FluentButton Appearance="Appearance.Accent" @onclick="RevealAsync">
                    @Loc["privacy.contact.reveal"]
                </FluentButton>
                break;
            case RevealState.Loading:
                <FluentLabel>@Loc["privacy.contact.revealing"]</FluentLabel>
                break;
            case RevealState.Error:
                <FluentLabel>@Loc["privacy.contact.error"]</FluentLabel>
                break;
            case RevealState.Loaded:
                @* Split across spans with an entity-encoded "@" so a regex like
                   [\w.+-]+@[\w.-]+ scanning source HTML finds nothing. The
                   visible text still reads correctly once the browser decodes. *@
                <FluentLabel>
                    <span>@_local</span><span>&#64;</span><span>@_domain</span>
                </FluentLabel>
                break;
        }
    </FluentStack>
</FluentStack>

<!-- Honeypot: invisible decoy to divert email scrapers -->
<a href="mailto:contact@example.com"
   aria-hidden="true"
   tabindex="-1"
   style="position: absolute; inset-inline-start: -9999px; opacity: 0; pointer-events: none;">
    contact@example.com
</a>

@code {
    private enum RevealState { Idle, Loading, Loaded, Error }

    private RevealState _state = RevealState.Idle;
    private string? _local;
    private string? _domain;

    private async Task RevealAsync()
    {
        _state = RevealState.Loading;
        try
        {
            var http = HttpFactory.CreateClient("api");
            var result = await http.GetFromJsonAsync<PrivacyEmailResponse>("api/privacy-contact/email");
            var email = result?.Email;
            if (string.IsNullOrEmpty(email))
            {
                _state = RevealState.Error;
                return;
            }

            var atIndex = email.IndexOf('@');
            if (atIndex <= 0 || atIndex == email.Length - 1)
            {
                _state = RevealState.Error;
                return;
            }

            _local = email[..atIndex];
            _domain = email[(atIndex + 1)..];
            _state = RevealState.Loaded;
        }
        catch
        {
            _state = RevealState.Error;
        }
    }

    private sealed record PrivacyEmailResponse(string Email);
}
