@page "/runs/new"
@attribute [Authorize]
@using Microsoft.AspNetCore.Components.Authorization
@using Lfm.App.Components
@using Lfm.App.Runs
@using Lfm.App.Services
@using Lfm.Contracts.Expansions
@using Lfm.Contracts.Guild
@using Lfm.Contracts.Instances
@using Lfm.Contracts.Runs
@using RunError = Lfm.App.Runs.RunError
@inject IInstancesClient InstancesClient
@inject IExpansionsClient ExpansionsClient
@inject IGuildClient GuildClient
@inject IRunsClient RunsClient
@inject NavigationManager Nav
@inject IStringLocalizer Loc
@inject AuthenticationStateProvider AuthStateProvider
@inject UnsavedChangesGuard UnsavedGuard
@implements IAsyncDisposable

<PageTitle>@Loc["createRun.title"]</PageTitle>

<FluentStack Orientation="Orientation.Vertical" VerticalGap="16" Style="max-inline-size:640px">
    <FluentLabel Typo="Typography.H1">@Loc["createRun.title"]</FluentLabel>

    @if (_loadError is not null)
    {
        <FluentMessageBar Intent="MessageIntent.Error">@_loadError</FluentMessageBar>
    }

    @if (_loading)
    {
        <FluentProgressRing />
    }
    else
    {
        <FluentCard Class="run-form-card">
            <FluentStack Orientation="Orientation.Vertical" VerticalGap="12">

                <section class="run-form-section" aria-labelledby="createRun-section-activity">
                    <h2 id="createRun-section-activity" class="run-form-section__title">@Loc["createRun.section.activity"]</h2>
                    <div class="run-form-section__fields">
                        <div>
                            <span id="createRun-activity-label" class="field__label">@Loc["createRun.activity"]</span>
                            <ToggleGroup TValue="ActivityKind"
                                         Options="_activityOptions"
                                         Value="_form.Activity"
                                         ValueChanged="HandleActivityChanged"
                                         AriaLabelledBy="createRun-activity-label"
                                         Disabled="@_submitting" />
                        </div>

                        @if (_form.Activity == ActivityKind.Dungeon && _form.Difficulty == "MYTHIC_KEYSTONE")
                        {
                            <div>
                                <span id="createRun-dungeonScope-label" class="field__label">@Loc["createRun.dungeonScope"]</span>
                                <ToggleGroup TValue="bool"
                                             Options="_dungeonScopeOptions"
                                             Value="_form.AnyDungeon"
                                             ValueChanged="HandleDungeonScopeChanged"
                                             AriaLabelledBy="createRun-dungeonScope-label"
                                             Disabled="@_submitting" />
                            </div>
                        }

                        @if (_form.ShowInstanceDropdown)
                        {
                            <FluentSelect Id="instance-select"
                                          Label="@Loc["createRun.instance"]"
                                          TOption="string"
                                          Value="@_form.InstanceId.ToString()"
                                          ValueChanged="@HandleInstanceChanged"
                                          Disabled="@_submitting">
                                <FluentOption Value="0">@Loc["createRun.selectInstance"]</FluentOption>
                                @foreach (var opt in _form.FilteredInstances)
                                {
                                    <FluentOption Value="@opt.InstanceId.ToString()">@opt.Name</FluentOption>
                                }
                            </FluentSelect>
                        }

                        @if (_form.ShowDifficultyToggle && _difficultyOptions.Count > 1)
                        {
                            <div>
                                <span id="createRun-difficulty-label" class="field__label">@Loc["createRun.difficulty"]</span>
                                <ToggleGroup TValue="string"
                                             Options="_difficultyOptions"
                                             Value="_form.Difficulty"
                                             ValueChanged="HandleDifficultyChanged"
                                             AriaLabelledBy="createRun-difficulty-label"
                                             Disabled="@_submitting" />
                            </div>
                        }
                    </div>
                </section>

                <section class="run-form-section" aria-labelledby="createRun-section-schedule">
                    <h2 id="createRun-section-schedule" class="run-form-section__title">@Loc["createRun.section.schedule"]</h2>
                    <div class="run-form-section__fields">
                        @if (_form.Difficulty == "MYTHIC_KEYSTONE")
                        {
                            <div>
                                <label for="keylevel-input" class="field__label">@Loc["createRun.keyLevel"]</label>
                                <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8" Wrap="true">
                                    <input id="keylevel-input"
                                           type="number"
                                           class="field__input"
                                           min="2"
                                           max="30"
                                           inputmode="numeric"
                                           placeholder="@Loc["createRun.keyLevel.placeholder"]"
                                           @bind="_form.KeystoneLevel"
                                           @bind:event="oninput"
                                           disabled="@_submitting"
                                           style="inline-size:7rem" />
                                    @* Keep the visible WNL label as the button's accessible name.
                                       FluentButton Title maps into aria-label, so the tooltip lives
                                       on a wrapper instead. *@
                                    <span title="@Loc["createRun.keyLevel.wnlDescription"]">
                                        <FluentButton Appearance="Appearance.Outline"
                                                      OnClick="@(() => _form.KeystoneLevel = 10)"
                                                      Disabled="@_submitting">
                                            @Loc["createRun.keyLevel.wnl"]
                                        </FluentButton>
                                    </span>
                                </FluentStack>
                                <small class="field__hint">
                                    @(_form.AnyDungeon ? Loc["createRun.keyLevel.hintAny"] : Loc["createRun.keyLevel.hintSpecific"])
                                </small>
                            </div>
                        }

                        <label class="field">
                            <span class="field__label">@Loc["createRun.startTime"]</span>
                            <input type="datetime-local"
                                   id="starttime-input"
                                   class="field__input"
                                   @bind="_form.StartTimeLocal"
                                   disabled="@_submitting"
                                   required />
                        </label>
                    </div>
                </section>

                <section class="run-form-section" aria-labelledby="createRun-section-signups">
                    <h2 id="createRun-section-signups" class="run-form-section__title">@Loc["createRun.section.signups"]</h2>
                    <div class="run-form-section__fields">
                        @if (_form.ShowSignupClose)
                        {
                            <label class="field">
                                <span class="field__label">@Loc["createRun.signupCloseTime"]</span>
                                <input type="datetime-local"
                                       id="signupclose-input"
                                       class="field__input"
                                       @bind="_form.SignupCloseLocal"
                                       disabled="@_submitting" />
                            </label>
                        }
                        else
                        {
                            <FluentButton Appearance="Appearance.Stealth"
                                          OnClick="@(() => _form.ShowSignupClose = true)"
                                          Disabled="@_submitting">
                                @Loc["createRun.addSignupDeadline"]
                            </FluentButton>
                        }
                    </div>
                </section>

                <section class="run-form-section" aria-labelledby="createRun-section-notes">
                    <h2 id="createRun-section-notes" class="run-form-section__title">@Loc["createRun.section.notes"]</h2>
                    <div class="run-form-section__fields">
                        <div>
                            <FluentTextArea Id="description-input"
                                            Label="@Loc["createRun.description"]"
                                            Value="@_form.Description"
                                            ValueChanged="@(v => _form.Description = v ?? string.Empty)"
                                            Disabled="@_submitting"
                                            Rows="5"
                                            Resize="TextAreaResize.Vertical"
                                            @attributes="DescriptionAttrs" />
                            <small class="field__hint">@(Loc["createRun.description.charCount", _form.Description.Length])</small>
                        </div>
                    </div>
                </section>

                <section class="run-form-section" aria-labelledby="createRun-section-actions">
                    <h2 id="createRun-section-actions" class="run-form-section__title">@Loc["createRun.section.actions"]</h2>
                    <div class="run-form-section__fields">
                        @if (CreateDisabledReason is { } submitReason)
                        {
                            <FluentMessageBar Class="run-submit-reason" Intent="MessageIntent.Warning">
                                @submitReason
                            </FluentMessageBar>
                        }

                        @if (_inlineError is not null)
                        {
                            <FluentMessageBar Intent="MessageIntent.Error">
                                @foreach (var m in _inlineError.Messages)
                                {
                                    <div>@m</div>
                                }
                            </FluentMessageBar>
                        }

                        <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8" Wrap="true">
                            <FluentButton Appearance="Appearance.Accent"
                                          OnClick="@HandleSubmit"
                                          Disabled="@(!_form.CanSubmit || !CanCreateRun || _submitting)">
                                @(_submitting ? Loc["createRun.creating"] : Loc["createRun.submit"])
                            </FluentButton>
                            <FluentButton Appearance="Appearance.Outline"
                                          OnClick="@(() => Nav.NavigateTo("/runs"))"
                                          Disabled="@_submitting">
                                @Loc["createRun.cancel"]
                            </FluentButton>
                        </FluentStack>
                    </div>
                </section>
            </FluentStack>
        </FluentCard>
    }
</FluentStack>

@if (UnsavedGuard.IsConfirmationVisible)
{
    <ConfirmDialog Open="true"
                   Title="@Loc["unsavedChanges.title"]"
                   Body="@Loc["unsavedChanges.body"]"
                   ConfirmText="@Loc["unsavedChanges.leave"]"
                   CancelText="@Loc["unsavedChanges.stay"]"
                   OnConfirm="@UnsavedGuard.ConfirmLeaveAsync"
                   OnCancel="@UnsavedGuard.StayAsync" />
}

@code {
    // ── Form state ─────────────────────────────────────────────────────────
    private readonly RunFormState _form = new();
    private GuildDto? _guild;
    private RunFormSnapshot? _initialFormSnapshot;
    private UnsavedChangesGuard.Registration? _unsavedChangesRegistration;

    // ── Page state ─────────────────────────────────────────────────────────
    private bool _loading = true;
    private bool _submitting;
    private bool _isSiteAdmin;
    private string? _loadError;
    private RunError? _inlineError;

    private bool CanCreateRun => _form.CanCreateGuildRuns || _isSiteAdmin;

    private string? CreateDisabledReason
    {
        get
        {
            if (!CanCreateRun) return Loc["createRun.visibility.guildDisabledReason"].Value;

            return _form.SubmitBlocker switch
            {
                RunFormSubmitBlocker.MissingStartTime => Loc["createRun.validation.startTimeRequired"].Value,
                RunFormSubmitBlocker.MissingInstance => Loc["createRun.validation.instanceRequired"].Value,
                RunFormSubmitBlocker.MissingKeystoneLevel => Loc["createRun.validation.keyLevelRequired"].Value,
                RunFormSubmitBlocker.InvalidKeystoneLevel => Loc["createRun.validation.keyLevelRange"].Value,
                _ => null,
            };
        }
    }

    // ── Options for the ToggleGroups ───────────────────────────────────────
    private IReadOnlyList<(ActivityKind, string)> _activityOptions = [];
    private IReadOnlyList<(bool, string)> _dungeonScopeOptions = [];
    private IReadOnlyList<(string, string)> _difficultyOptions = [];

    private static readonly Dictionary<string, object> DescriptionAttrs = new()
    {
        ["enterkeyhint"] = "done",
        ["maxlength"] = (int?)2000,
    };

    // ── Lifecycle ──────────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        try
        {
            var expansionsTask = ExpansionsClient.ListAsync(CancellationToken.None);
            var instancesTask = InstancesClient.ListAsync(CancellationToken.None);
            var guildTask = GuildClient.GetAsync(CancellationToken.None);
            var authTask = AuthStateProvider.GetAuthenticationStateAsync();
            await Task.WhenAll(expansionsTask, instancesTask);

            _form.LoadOptions(InstanceOptions.Build(await instancesTask), await expansionsTask);
            _isSiteAdmin = (await authTask).User.IsInRole("SiteAdmin");

            try { _guild = await guildTask; }
            catch { _guild = null; }

            RebuildStaticOptions();
            SyncDifficultyOptionTuples();
            ApplyVisibilityDefault();

            // Start-time defaults to next Thursday at 20:00 local wall-clock.
            _form.StartTimeLocal = RunTimeDefaults.NextThursday20(DateTime.Now);
        }
        catch (Exception ex)
        {
            _loadError = $"Failed to load form data: {ex.Message}";
        }
        finally
        {
            _loading = false;
            if (_loadError is null)
            {
                RegisterUnsavedChangesGuard();
            }
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_unsavedChangesRegistration is not null)
        {
            await UnsavedGuard.RefreshAsync();
        }
    }

    // ── Event handlers ─────────────────────────────────────────────────────
    private void HandleActivityChanged(ActivityKind value)
    {
        _form.OnActivityChanged(value);
        SyncDifficultyOptionTuples();
    }

    private void HandleDungeonScopeChanged(bool anyDungeon)
    {
        _form.OnDungeonScopeChanged(anyDungeon);
        SyncDifficultyOptionTuples();
    }

    private void HandleInstanceChanged(string value)
    {
        if (!int.TryParse(value, out var id)) return;
        _form.OnInstanceChanged(id);
        SyncDifficultyOptionTuples();
    }

    private void HandleDifficultyChanged(string value)
    {
        _form.OnDifficultyChanged(value);
    }

    // ── Option builders ────────────────────────────────────────────────────
    private void RebuildStaticOptions()
    {
        _activityOptions = new (ActivityKind, string)[]
        {
            (ActivityKind.Raid, Loc["createRun.activity.raid"].Value),
            (ActivityKind.Dungeon, Loc["createRun.activity.dungeon"].Value),
        };
        _dungeonScopeOptions = new (bool, string)[]
        {
            (true, Loc["createRun.dungeonScope.any"].Value),
            (false, Loc["createRun.dungeonScope.specific"].Value),
        };
    }

    private void SyncDifficultyOptionTuples()
    {
        _form.RefreshDifficultyOptions();
        _difficultyOptions = _form.DifficultyOptions
            .Select(d => (d.DifficultyId, d.DisplayName))
            .ToList();
    }

    private void ApplyVisibilityDefault()
    {
        _form.CanCreateGuildRuns = _guild?.MemberPermissions?.CanCreateGuildRuns ?? false;
        _form.Visibility = "GUILD";
    }

    // The native <input type="datetime-local"> binds wall-clock time with no
    // offset, so we must convert back to UTC before sending — otherwise the
    // stored value would differ from the user's intent by the browser's TZ
    // offset and round-trips through EditRunPage would drift on every save.
    private static string? ToIsoOrNull(DateTime? dt) =>
        dt is null ? null : dt.Value.ToUniversalTime().ToString("o");

    // ── Submit ─────────────────────────────────────────────────────────────
    private async Task HandleSubmit()
    {
        _submitting = true;
        _inlineError = null;
        var isMythicPlus = _form.Activity == ActivityKind.Dungeon && _form.Difficulty == "MYTHIC_KEYSTONE";
        var instanceOption = isMythicPlus && _form.AnyDungeon
            ? null
            : _form.FilteredInstances.FirstOrDefault(o => o.InstanceId == _form.InstanceId);

        try
        {
            var request = new CreateRunRequest(
                StartTime: ToIsoOrNull(_form.StartTimeLocal) ?? string.Empty,
                SignupCloseTime: ToIsoOrNull(_form.SignupCloseLocal),
                Description: string.IsNullOrWhiteSpace(_form.Description) ? null : _form.Description,
                Visibility: "GUILD",
                InstanceId: instanceOption?.InstanceId,
                InstanceName: instanceOption?.Name,
                Difficulty: _form.Difficulty,
                Size: _form.Size,
                KeystoneLevel: isMythicPlus ? _form.KeystoneLevel : null);

            var created = await RunsClient.CreateAsync(request, CancellationToken.None);
            if (created is null)
            {
                _inlineError = new RunError(RunErrorKind.Unknown, [Loc["createRun.failed"].Value]);
                return;
            }

            await DisposeUnsavedChangesGuardAsync();
            Nav.NavigateTo($"/runs/{Uri.EscapeDataString(created.Id)}");
        }
        catch (Exception ex)
        {
            _inlineError = RunErrorParser.Network(ex);
        }
        finally
        {
            _submitting = false;
        }
    }

    private void RegisterUnsavedChangesGuard()
    {
        _initialFormSnapshot = RunFormSnapshot.From(_form);
        UnsavedGuard.StateChanged += HandleUnsavedChangesStateChanged;
        _unsavedChangesRegistration = UnsavedGuard.Register(this, HasUnsavedChanges);
    }

    private bool HasUnsavedChanges() =>
        !_submitting
        && _initialFormSnapshot is not null
        && RunFormSnapshot.From(_form) != _initialFormSnapshot;

    private void HandleUnsavedChangesStateChanged() => _ = InvokeAsync(StateHasChanged);

    private async ValueTask DisposeUnsavedChangesGuardAsync()
    {
        UnsavedGuard.StateChanged -= HandleUnsavedChangesStateChanged;
        if (_unsavedChangesRegistration is not null)
        {
            await _unsavedChangesRegistration.DisposeAsync();
            _unsavedChangesRegistration = null;
        }
    }

    public async ValueTask DisposeAsync() => await DisposeUnsavedChangesGuardAsync();

    private sealed record RunFormSnapshot(
        int ExpansionId,
        ActivityKind Activity,
        int InstanceId,
        string Difficulty,
        int Size,
        int? KeystoneLevel,
        bool AnyDungeon,
        DateTime? StartTimeLocal,
        DateTime? SignupCloseLocal,
        bool ShowSignupClose,
        string Visibility,
        string Description)
    {
        public static RunFormSnapshot From(RunFormState form) =>
            new(
                form.ExpansionId,
                form.Activity,
                form.InstanceId,
                form.Difficulty,
                form.Size,
                form.KeystoneLevel,
                form.AnyDungeon,
                form.StartTimeLocal,
                form.SignupCloseLocal,
                form.ShowSignupClose,
                form.Visibility,
                form.Description);
    }
}
