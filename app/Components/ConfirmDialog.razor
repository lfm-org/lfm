@inject IJSRuntime JS
@implements IAsyncDisposable

<dialog @ref="_dialogRef"
        class="confirm-dialog"
        role="alertdialog"
        aria-labelledby="@TitleId"
        aria-describedby="@BodyId"
        @onclose="HandleNativeDismissAsync"
        @oncancel="HandleNativeDismissAsync">
    <div class="confirm-dialog__surface">
        <h2 id="@TitleId" class="confirm-dialog__title">@Title</h2>
        <p id="@BodyId" class="confirm-dialog__body">@Body</p>
        <div class="confirm-dialog__actions">
            <FluentButton Appearance="Appearance.Accent"
                          OnClick="@OnConfirm"
                          Disabled="@ConfirmDisabled">
                @ConfirmText
            </FluentButton>
            <FluentButton Appearance="Appearance.Outline"
                          OnClick="@OnCancel"
                          Disabled="@ConfirmDisabled"
                          autofocus="true">
                @CancelText
            </FluentButton>
        </div>
    </div>
</dialog>

@code {
    [Parameter] public bool Open { get; set; }
    [Parameter, EditorRequired] public string Title { get; set; } = string.Empty;
    [Parameter, EditorRequired] public string Body { get; set; } = string.Empty;
    [Parameter, EditorRequired] public string ConfirmText { get; set; } = string.Empty;
    [Parameter, EditorRequired] public string CancelText { get; set; } = string.Empty;
    [Parameter] public bool ConfirmDisabled { get; set; }
    [Parameter] public EventCallback OnConfirm { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    private readonly string _id = Guid.NewGuid().ToString("N");
    private ElementReference _dialogRef;
    private IJSObjectReference? _dialogModule;
    private bool _shown;
    private bool _dismissedNatively;

    private string TitleId => $"confirm-dialog-title-{_id}";
    private string BodyId => $"confirm-dialog-body-{_id}";

    protected override void OnParametersSet()
    {
        if (!Open)
        {
            _dismissedNatively = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (Open && !_shown && !_dismissedNatively)
        {
            _dialogModule ??= await JS.InvokeAsync<IJSObjectReference>("import", "./js/dialog.js");
            await _dialogModule.InvokeVoidAsync("showModal", _dialogRef);
            _shown = true;
        }
        else if (!Open && _shown && _dialogModule is not null)
        {
            await _dialogModule.InvokeVoidAsync("close", _dialogRef);
            _shown = false;
        }
    }

    private async Task HandleNativeDismissAsync()
    {
        if (!_shown)
        {
            return;
        }

        _shown = false;
        _dismissedNatively = true;
        await OnCancel.InvokeAsync();
    }

    public async ValueTask DisposeAsync()
    {
        if (_dialogModule is not null)
        {
            await _dialogModule.DisposeAsync();
        }
    }
}
