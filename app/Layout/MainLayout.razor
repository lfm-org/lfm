@inherits LayoutComponentBase
@implements IDisposable
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using Lfm.App.Auth
@using Lfm.App.Services
@inject NavigationManager Nav
@inject IConfiguration Config
@inject IThemeService ThemeService
@inject IStringLocalizer Loc
@inject ILocaleService LocaleService
@inject IJSRuntime JS

<FluentToastProvider />

<div style="min-block-size:100svh;display:flex;flex-direction:column">
    <!-- Skip-to-content link for keyboard users -->
    <a href="#main-content" class="skip-link">@Loc["a11y.skipToContent"]</a>

    <!-- Top navbar -->
    <header style="background:var(--neutral-layer-4);border-bottom:1px solid var(--neutral-stroke-rest);padding:0 16px">
        <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8" Style="align-items:center;height:48px">
            <FluentAnchor Href="/runs" Style="font-weight:700;font-size:1.1rem;text-decoration:none">@Loc["nav.logo"]</FluentAnchor>

            <AuthorizeView>
                <Authorized Context="accountAuth">
                    @* Plain <div> (not FluentStack) so `.desktop-nav { display: none }` isn't
                       overridden by FluentStack's inline display:flex at narrow viewports. *@
                    <div class="desktop-nav">
                        <FluentAnchor Href="/runs">@Loc["nav.runs"]</FluentAnchor>
                        <FluentAnchor Href="/guild">@Loc["nav.guild"]</FluentAnchor>
                        <FluentAnchor Href="/characters">@Loc["nav.characters"]</FluentAnchor>
                        <AuthorizeView Roles="SiteAdmin" Context="adminAuth">
                            <FluentAnchor Href="/admin/reference">@Loc["nav.admin"]</FluentAnchor>
                        </AuthorizeView>
                    </div>
                    <div style="margin-inline-start:auto;display:flex;align-items:center;gap:4px">
                        <FluentButton Appearance="Appearance.Stealth"
                                      Class="mobile-nav-toggle"
                                      Title="@Loc["nav.toggleMenu"]"
                                      aria-label="@Loc["nav.toggleMenu"]"
                                      OnClick="@ToggleMobileMenu">
                            &#9776;
                        </FluentButton>
                        <FluentButton Appearance="Appearance.Stealth"
                                      Title="@_themeTooltip"
                                      aria-label="@_themeTooltip"
                                      OnClick="@ToggleTheme">
                            @_themeIcon
                        </FluentButton>
                        <div class="account-menu-container">
                            <FluentButton Appearance="Appearance.Stealth"
                                          Class="account-menu-trigger"
                                          Title="@SelectedCharacterName(accountAuth.User)"
                                          aria-label="@Loc["nav.accountMenu", SelectedCharacterName(accountAuth.User)]"
                                          aria-haspopup="menu"
                                          aria-expanded="@(_showAccountMenu ? "true" : "false")"
                                          OnClick="@ToggleAccountMenu">
                                @if (SelectedCharacterPortraitUrl(accountAuth.User) is { } portraitUrl)
                                {
                                    <img class="account-avatar" src="@portraitUrl" alt="" />
                                }
                                else
                                {
                                    <span class="account-avatar account-avatar-initial" aria-hidden="true">
                                        @SelectedCharacterInitial(accountAuth.User)
                                    </span>
                                }
                                <span class="account-character-name">@SelectedCharacterName(accountAuth.User)</span>
                            </FluentButton>
                            <div class="account-menu @(_showAccountMenu ? "open" : "")"
                                 role="menu"
                                 aria-hidden="@(!_showAccountMenu)">
                                <a class="account-menu-item" role="menuitem" href="/characters" @onclick="@CloseMenus">
                                    @Loc["nav.characters"]
                                </a>
                                <a class="account-menu-item" role="menuitem" href="/guild" @onclick="@CloseMenus">
                                    @Loc["nav.guild"]
                                </a>
                                <AuthorizeView Roles="SiteAdmin" Context="adminAccountAuth">
                                    <a class="account-menu-item" role="menuitem" href="/admin/reference" @onclick="@CloseMenus">
                                        @Loc["nav.admin"]
                                    </a>
                                </AuthorizeView>
                                <FluentButton Appearance="Appearance.Stealth"
                                              Class="account-menu-item account-sign-out"
                                              role="menuitem"
                                              OnClick="@HandleLogout">
                                    @Loc["nav.signOut"]
                                </FluentButton>
                            </div>
                        </div>
                    </div>
                </Authorized>
                <NotAuthorized>
                    <div style="margin-inline-start:auto;display:flex;align-items:center;gap:4px">
                        <FluentButton Appearance="Appearance.Stealth"
                                      Title="@_themeTooltip"
                                      aria-label="@_themeTooltip"
                                      OnClick="@ToggleTheme">
                            @_themeIcon
                        </FluentButton>
                        <FluentAnchor Href="/login">@Loc["nav.signIn"]</FluentAnchor>
                    </div>
                </NotAuthorized>
            </AuthorizeView>
        </FluentStack>
    </header>

    <!-- Mobile navigation menu -->
    <AuthorizeView>
        <Authorized>
            <nav class="mobile-menu @(_showMobileMenu ? "open" : "")"
                 style="background:var(--neutral-layer-4);border-bottom:1px solid var(--neutral-stroke-rest);padding:8px 16px">
                <FluentStack Orientation="Orientation.Vertical" VerticalGap="4">
                    <FluentAnchor Href="/runs">@Loc["nav.runs"]</FluentAnchor>
                    <FluentAnchor Href="/guild">@Loc["nav.guild"]</FluentAnchor>
                    <FluentAnchor Href="/characters">@Loc["nav.characters"]</FluentAnchor>
                    <AuthorizeView Roles="SiteAdmin" Context="adminMobileAuth">
                        <FluentAnchor Href="/admin/reference">@Loc["nav.admin"]</FluentAnchor>
                    </AuthorizeView>
                </FluentStack>
            </nav>
        </Authorized>
    </AuthorizeView>

    <!-- Page content -->
    <main id="main-content" tabindex="-1" @ref="_mainRef" style="flex:1;padding-block:24px;padding-inline:16px">
        @Body
    </main>

    <!-- Footer with privacy link, AGPL §13 source link, and language toggle.
         The "Source" anchor discharges the AGPL §13 obligation to prominently
         offer the Corresponding Source to every user interacting over the
         network. Fork operators: override SourceRepositoryUrl in
         appsettings.json to point at your modified source repository. -->
    <footer style="border-top:1px solid var(--neutral-stroke-rest);padding:8px 16px">
        <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8" Wrap="true" Style="align-items:center;justify-content:center">
            <FluentAnchor Href="/privacy">@Loc["footer.privacyPolicy"]</FluentAnchor>
            <span>|</span>
            <FluentAnchor Href="@_sourceUrl" Target="_blank" rel="noopener external">@Loc["footer.source"]</FluentAnchor>
            <span>|</span>
            <FluentButton Appearance="Appearance.Stealth"
                          OnClick="@(() => LocaleService.SetLocale("en"))"
                          Style="@(LocaleService.CurrentLocale == "en" ? "font-weight:700" : "")">
                @Loc["locale.en"]
            </FluentButton>
            <FluentButton Appearance="Appearance.Stealth"
                          OnClick="@(() => LocaleService.SetLocale("fi"))"
                          Style="@(LocaleService.CurrentLocale == "fi" ? "font-weight:700" : "")">
                @Loc["locale.fi"]
            </FluentButton>
        </FluentStack>
    </footer>
</div>

<style>
    .account-menu-container {
        position: relative;
        display: inline-flex;
        align-items: center;
    }

    .account-menu-trigger::part(control) {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        max-inline-size: 192px;
    }

    .account-avatar {
        inline-size: 28px;
        block-size: 28px;
        border-radius: 50%;
        flex: 0 0 auto;
        object-fit: cover;
    }

    .account-avatar-initial {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: var(--accent-fill-rest);
        color: var(--foreground-on-accent-rest, #fff);
        font-weight: 700;
        line-height: 1;
    }

    .account-character-name {
        min-inline-size: 0;
        max-inline-size: 128px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .account-menu {
        display: none;
        position: absolute;
        inset-block-start: calc(100% + 4px);
        inset-inline-end: 0;
        z-index: 10;
        min-inline-size: 160px;
        padding: 4px;
        background: var(--neutral-layer-4);
        border: 1px solid var(--neutral-stroke-rest);
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.18);
    }

    .account-menu.open {
        display: grid;
        gap: 2px;
    }

    .account-menu-item {
        display: flex;
        align-items: center;
        inline-size: 100%;
        min-block-size: 32px;
        padding: 4px 8px;
        color: var(--neutral-foreground-rest);
        text-align: start;
        text-decoration: none;
    }

    .account-menu-item:hover,
    .account-menu-item:focus {
        background: var(--neutral-fill-stealth-hover);
    }
</style>

@code {
    private const string DefaultSourceRepositoryUrl = "https://github.com/lfm-org/lfm";

    private bool _showMobileMenu;
    private bool _showAccountMenu;
    private bool _navigated;
    private ElementReference _mainRef;
    private string _themeIcon = "\u2600\ufe0f";
    private string _themeTooltip = string.Empty;
    private string _sourceUrl = DefaultSourceRepositoryUrl;

    protected override void OnInitialized()
    {
        Nav.LocationChanged += OnLocationChanged;
        ThemeService.OnChange += OnThemeChanged;
        LocaleService.OnLocaleChanged += HandleLocaleChanged;
        UpdateThemeDisplay();

        // Resolve the AGPL source URL from config. Fork operators override
        // SourceRepositoryUrl in appsettings.json (or via environment) to
        // satisfy AGPL \u00a713 on their deployment.
        var configured = Config["SourceRepositoryUrl"];
        if (!string.IsNullOrWhiteSpace(configured))
        {
            _sourceUrl = configured;
        }
    }

    private void UpdateThemeDisplay()
    {
        var isDark = ThemeService.Mode == DesignThemeModes.Dark;
        _themeIcon = isDark ? "\u2600\ufe0f" : "\ud83c\udf19";
        _themeTooltip = isDark ? Loc["theme.switchToLight"] : Loc["theme.switchToDark"];
    }

    private void ToggleTheme()
    {
        ThemeService.Toggle();
        UpdateThemeDisplay();
    }

    private void OnThemeChanged()
    {
        UpdateThemeDisplay();
        InvokeAsync(StateHasChanged);
    }

    private void ToggleMobileMenu()
    {
        _showMobileMenu = !_showMobileMenu;
        _showAccountMenu = false;
    }

    private void ToggleAccountMenu()
    {
        _showAccountMenu = !_showAccountMenu;
        _showMobileMenu = false;
    }

    private void CloseMenus()
    {
        _showMobileMenu = false;
        _showAccountMenu = false;
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        CloseMenus();
        _navigated = true;
        InvokeAsync(StateHasChanged);
    }

    private string SelectedCharacterName(ClaimsPrincipal user)
        => user.FindFirst(AppAuthenticationStateProvider.SelectedCharacterNameClaim)?.Value
           ?? Loc["nav.yourAccount"];

    private string? SelectedCharacterPortraitUrl(ClaimsPrincipal user)
        => user.FindFirst(AppAuthenticationStateProvider.SelectedCharacterPortraitUrlClaim)?.Value;

    private string SelectedCharacterInitial(ClaimsPrincipal user)
    {
        var name = SelectedCharacterName(user);
        return string.IsNullOrWhiteSpace(name) ? "?" : name[..1].ToUpperInvariant();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("lfmSetDocumentLang", LocaleService.CurrentLocale);
        }

        if (_navigated)
        {
            _navigated = false;
            try
            {
                await _mainRef.FocusAsync();
            }
            catch (InvalidOperationException) { /* mainRef not bound yet — page is being torn down. */ }
            catch (Microsoft.JSInterop.JSDisconnectedException) { /* JS channel disposed during teardown. */ }
        }
    }

    private async void HandleLocaleChanged()
    {
        // async void crosses JS interop; an unhandled exception escapes to
        // the SynchronizationContext and can crash the WASM circuit. Mirror
        // the OnAfterRenderAsync handling for the same teardown failure mode.
        try
        {
            await JS.InvokeVoidAsync("lfmSetDocumentLang", LocaleService.CurrentLocale);
            await InvokeAsync(StateHasChanged);
        }
        catch (Microsoft.JSInterop.JSDisconnectedException) { /* JS channel disposed during teardown. */ }
        catch (TaskCanceledException) { /* Render disposed mid-await. */ }
    }

    private void HandleLogout()
    {
        // Mirror the login flow (see LoginPage.razor): top-level browser
        // navigation to the API endpoint so the server's cookie-clear
        // Set-Cookie header is processed by the browser as part of a real
        // navigation response. An earlier HttpClient.PostAsync-based
        // implementation was silently eaten by HttpClient timeouts on cold
        // Functions starts and left the session alive (issue #53).
        CloseMenus();
        var apiBase = Config["ApiBaseUrl"]?.TrimEnd('/') ?? string.Empty;
        Nav.NavigateTo($"{apiBase}/api/v1/battlenet/logout", forceLoad: true);
    }

    public void Dispose()
    {
        Nav.LocationChanged -= OnLocationChanged;
        ThemeService.OnChange -= OnThemeChanged;
        LocaleService.OnLocaleChanged -= HandleLocaleChanged;
    }
}
