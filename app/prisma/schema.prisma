datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum RaidVisibility {
  PUBLIC
  GUILD
}

enum Attendance {
  NO
  IF_ROOM
  YES
}

model Raider {
  id                  Int        @id @default(autoincrement())
  createdTime         DateTime   @default(now()) @map("created_time") @db.Timestamptz(6)
  updatedTime         DateTime   @updatedAt      @map("updated_time") @db.Timestamptz(6)
  battleNetId         String     @unique         @map("battle_net_id")
  guildName           String?    @map("guild_name")
  selectedCharacterId Int?       @map("selected_character")
  selectedCharacter   Character? @relation("selected_character", fields: [selectedCharacterId], references: [id], onDelete: SetNull)
  characters          Character[] @relation("owned_characters")
  raids               Raid[]

  @@map("raider")
}

model Character {
  id             Int             @id @default(autoincrement())
  updatedTime    DateTime        @updatedAt @map("updated_time") @db.Timestamptz(6)
  region         String
  realm          String
  name           String
  level          Int?
  classId        Int?            @map("class")
  raceId         Int?            @map("race")
  portraitUrl    String?         @map("portrait_url")
  raiderId       Int             @map("raider")
  class          WowClass?       @relation(fields: [classId], references: [id])
  race           WowRace?        @relation(fields: [raceId],  references: [id])
  raider         Raider          @relation("owned_characters", fields: [raiderId], references: [id])
  raidCharacters RaidCharacter[]
  selectedBy     Raider[]        @relation("selected_character")

  @@unique([region, realm, name], name: "unique_region_realm_name")
  @@map("character")
}

model Raid {
  id              Int             @id @default(autoincrement())
  startTime       DateTime        @default(now()) @map("start_time")        @db.Timestamptz(6)
  updatedTime     DateTime        @updatedAt       @map("updated_time")      @db.Timestamptz(6)
  signupCloseTime DateTime        @map("signup_close_time")                  @db.Timestamptz(6)
  description     String?
  mode            String?
  visibility      RaidVisibility  @default(PUBLIC)
  creatorGuild    String?         @map("creator_guild")
  instanceId      Int             @map("instance")
  creatorId       Int             @map("creator")
  instance        WowInstance     @relation(fields: [instanceId], references: [id])
  creator         Raider          @relation(fields: [creatorId],  references: [id])
  raidCharacters  RaidCharacter[]

  @@map("raid")
}

model RaidCharacter {
  id                 Int        @id @default(autoincrement())
  raidId             Int        @map("raid")
  characterId        Int        @map("character")
  desiredAttendance  Attendance @default(IF_ROOM) @map("desired_attendance")
  reviewedAttendance Attendance @default(IF_ROOM) @map("reviewed_attendance")
  raid               Raid       @relation(fields: [raidId],      references: [id])
  character          Character  @relation(fields: [characterId], references: [id])

  @@map("raid_character")
}

model WowClass {
  id          Int         @id
  updatedTime DateTime    @updatedAt @map("updated_time") @db.Timestamptz(6)
  name        String
  characters  Character[]

  @@map("wow_class")
}

model WowRace {
  id          Int         @id
  updatedTime DateTime    @updatedAt @map("updated_time") @db.Timestamptz(6)
  faction     String
  name        String
  characters  Character[]

  @@map("wow_race")
}

model WowInstance {
  id          Int      @id
  updatedTime DateTime @updatedAt @map("updated_time") @db.Timestamptz(6)
  name        String
  type        String
  minLevel    Int      @map("minimum_level")
  expansionId Int      @map("expansion_id")
  modes       String[]
  raids       Raid[]

  @@map("wow_instance")
}

model WowMeta {
  id          Int      @id @default(autoincrement())
  createdTime DateTime @default(now()) @map("created_time") @db.Timestamptz(6)
  success     Boolean

  @@map("wow_meta")
}
